/* noforget/app.wxss - Morandi Morning Mist UI system */

@import 'theme-default.wxss';

/* ===== 动态主题注入区（由 JS setData 注入） ===== */
/*
 * --theme-accent:           主题强调色
 * --theme-accent-rgb:       RGB分离（供rgba()使用）
 * --theme-accent-light:     10%透明强调色
 * --theme-text-primary:     主文字色
 * --theme-text-secondary:   次文字色
 * --theme-text-accent:      强调文字色（=accent）
 * --theme-background:       页面背景色
 * --theme-card-bg:          卡片背景色
 * --theme-border:           边框色
 * --theme-shadow:           轻阴影（通用）
 * --theme-shadow-card:      卡片阴影（更重）
 * --theme-radius-card:      卡片圆角
 * --theme-radius-btn:       按钮圆角
 * --theme-icon-color:       图标颜色
 * --theme-duration-micro:   微交互时长（150ms）
 * --theme-ease-out-quart:  退出缓出曲线
 */

/* ===== 全局基础 ===== */
page {
  font-family: var(--theme-font-family);
  background:
    radial-gradient(circle at 12% 8%, rgba(216, 183, 200, 0.12), transparent 34%),
    radial-gradient(circle at 88% 12%, rgba(183, 202, 216, 0.12), transparent 32%),
    radial-gradient(circle at 48% 92%, rgba(230, 184, 148, 0.08), transparent 38%),
    var(--theme-background);
  color: var(--theme-text-primary);
  font-size: 15px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  touch-action: manipulation;
}

.mist-canvas {
  background:
    radial-gradient(circle at 10% 4%, rgba(216, 183, 200, 0.5), transparent 35%),
    radial-gradient(circle at 92% 8%, rgba(183, 202, 216, 0.42), transparent 32%),
    radial-gradient(circle at 52% 92%, rgba(230, 184, 148, 0.32), transparent 42%),
    linear-gradient(180deg, var(--theme-background-warm), var(--theme-background));
  background-size: 130% 130%;
  animation: mist-drift 16s ease-in-out infinite alternate;
}

.mist-panel {
  background:
    linear-gradient(135deg, rgba(255,255,255,0.78), rgba(255,255,255,0.52)),
    radial-gradient(circle at 0% 0%, rgba(216,183,200,0.22), transparent 42%),
    radial-gradient(circle at 100% 20%, rgba(183,202,216,0.18), transparent 44%);
  border: 1rpx solid var(--theme-border);
  border-radius: var(--theme-radius-card-rpx);
  box-shadow: var(--theme-shadow-card);
  backdrop-filter: blur(18px) saturate(138%);
  -webkit-backdrop-filter: blur(18px) saturate(138%);
}

.mist-primary {
  background:
    radial-gradient(circle at 30% 10%, rgba(216,183,200,0.52), transparent 50%),
    radial-gradient(circle at 82% 28%, rgba(183,202,216,0.48), transparent 52%),
    linear-gradient(135deg, rgba(168,121,114,0.92), rgba(164,145,174,0.9));
  color: #FFFDF8;
  border: 1rpx solid rgba(255,255,255,0.42);
  box-shadow: 0 16rpx 34rpx rgba(168,121,114,0.16);
}

.mist-secondary {
  background: rgba(255,255,255,0.48);
  color: var(--theme-text-secondary);
  border: 1rpx solid var(--theme-border);
}

.text-brand {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: var(--theme-text-primary);
}

.text-title {
  font-size: var(--theme-title-size);
  font-weight: 600;
  line-height: 1.25;
  color: var(--theme-text-primary);
  letter-spacing: 0.3rpx;
}

.text-section {
  font-size: var(--theme-section-size);
  font-weight: 600;
  line-height: 1.35;
  color: var(--theme-text-primary);
}

.text-body {
  font-size: var(--theme-body-size);
  font-weight: 400;
  line-height: 1.65;
  color: var(--theme-text-secondary);
}

.text-caption {
  font-size: var(--theme-caption-size);
  font-weight: 400;
  line-height: 1.45;
  color: var(--theme-text-muted);
}

/* ===== 通用卡片 ===== */
/* UX: Layout - Content Jumping prevention, aspect-ratio reserved */
.card {
  background:
    linear-gradient(135deg, rgba(255,255,255,0.78), rgba(255,255,255,0.52)),
    radial-gradient(circle at 0% 0%, rgba(216,183,200,0.2), transparent 42%);
  border-radius: var(--theme-radius-card, 16px);
  box-shadow: var(--theme-shadow-card);
  border: 1px solid var(--theme-border);
  overflow: hidden;
  /* UX: Transform Performance - 动画只改 transform/opacity */
  transition:
    transform var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, cubic-bezier(0.25,1,0.5,1)),
    box-shadow var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, cubic-bezier(0.25,1,0.5,1)),
    opacity var(--theme-duration-micro, 150ms) ease;
}

.card:active {
  /* UX: Animation - 按下反馈弹性 scale */
  transform: scale(0.97);
}

/* UX: prefers-reduced-motion 降级处理 */
@media (prefers-reduced-motion: reduce) {
  .card:active {
    transform: none;
  }
}

/* ===== 通用按钮 ===== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--theme-radius-btn, 999rpx);
  min-height: 44px;    /* UX: Touch Target ≥44px */
  min-width: 44px;
  padding: 10px 20px;
  font-size: 15px;
  font-weight: 600;
  color: #ffffff;
  background:
    radial-gradient(circle at 30% 10%, rgba(216,183,200,0.52), transparent 50%),
    radial-gradient(circle at 82% 28%, rgba(183,202,216,0.48), transparent 52%),
    linear-gradient(135deg, rgba(168,121,114,0.92), rgba(164,145,174,0.9));
  border: 1rpx solid rgba(255,255,255,0.42);
  cursor: pointer;     /* UX: cursor-pointer on clickable */
  outline: none;
  transition:
    transform var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, cubic-bezier(0.25,1,0.5,1)),
    box-shadow var(--theme-duration-micro, 150ms) var(--theme-ease-out-quart, cubic-bezier(0.25,1,0.5,1)),
    background var(--theme-duration-micro, 150ms) ease;
  /* UX: No bounce/elastic - cubic-bezier is smooth */
}

.btn:active {
  transform: scale(0.97) translateY(1px);
  box-shadow: 0 8rpx 20rpx rgba(91,74,60,0.08);
}

.btn-ghost {
  background: transparent;
  color: var(--theme-text-secondary);
  border: 1.5px solid var(--theme-border);
}

/* ===== 分割线 ===== */
.divider {
  width: 50px;
  height: 1px;
  background: var(--theme-border);
  opacity: 0.4;
  margin: 20px auto;
}

/* ===== 底部安全区 ===== */
/* UX: Layout - Fixed Positioning accounts for safe area */
.safe-area-bottom {
  padding-bottom: calc(44px + env(safe-area-inset-bottom, 20px));
}

/* ===== 蒙版层 ===== */
/* UX: Z-Index Management - 明确层级 */
/* z-index scale: modal(500) > overlay(300) > card(100) > base(1) */
.overlay {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(circle at 50% 55%, rgba(216,183,200,0.26), transparent 36%),
    rgba(47, 42, 37, 0.24);
  z-index: 300;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.mist-bloom {
  animation: mist-bloom 420ms var(--ease-out-quart) both;
}

/* ===== 微交互：涟漪效果（按需启用） ===== */
/* 触摸时产生 material design 涟漪 */
/* 注意：小程序无 CSS 涟漪，用 transform scale 代替 */

/* pages/almanac/almanac.wxss - 现代每日黄历 */

.almanac-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 12% 4%, rgba(239, 225, 169, 0.46) 0, rgba(239, 225, 169, 0) 38%),
    radial-gradient(circle at 88% 14%, rgba(205, 231, 255, 0.58) 0, rgba(205, 231, 255, 0) 36%),
    radial-gradient(circle at 20% 84%, rgba(174, 231, 222, 0.32) 0, rgba(174, 231, 222, 0) 42%),
    radial-gradient(circle at 78% 72%, rgba(251, 207, 222, 0.28) 0, rgba(251, 207, 222, 0) 38%),
    radial-gradient(circle at 52% 42%, rgba(255, 255, 255, 0.5) 0, rgba(255, 255, 255, 0) 44%),
    #F7F9FE;
  background-size: 144% 144%;
  animation: almanac-mist-drift 18s ease-in-out infinite alternate;
  color: #243247;
}

@keyframes almanac-mist-drift {
  0% { background-position: 0% 8%; }
  100% { background-position: 100% 92%; }
}

.almanac-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-sizing: border-box;
  background: rgba(247, 249, 254, 0.68);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}

.nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.back-btn, .nav-space {
  width: 68rpx;
  height: 68rpx;
}

.back-btn {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-left: 8rpx;
  box-sizing: border-box;
}

.back-btn-icon {
  position: relative;
  width: 40rpx;
  height: 40rpx;
}

.back-btn-icon::before {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 9rpx;
  width: 16rpx;
  height: 16rpx;
  border-left: 2.6rpx solid #243247;
  border-bottom: 2.6rpx solid #243247;
  border-radius: 2rpx;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
  margin-right: -6rpx;
  color: #243247;
}

.almanac-scroll {
  height: 100vh;
  box-sizing: border-box;
}

.hero-card,
.action-card,
.modern-card,
.history-card {
  margin: 0 40rpx 28rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(228, 235, 246, 0.92);
  border-radius: 36rpx;
  box-shadow: 0 16rpx 38rpx rgba(83, 99, 129, 0.05);
  box-sizing: border-box;
}

.hero-card {
  margin: 0 40rpx 24rpx;
  background: rgba(255, 255, 255, 0.82);
  border-radius: 38rpx;
  box-shadow: 0 18rpx 44rpx rgba(83, 99, 129, 0.06);
  padding: 34rpx 38rpx 30rpx;
  position: relative;
}

.hero-topline {
  display: flex;
  justify-content: space-between;
  color: #7F8CA4;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  margin-bottom: 28rpx;
}

.hero-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.lunar-title {
  display: block;
  font-family: "Songti SC", "PingFang SC", serif;
  font-size: 52rpx;
  font-weight: 500;
  color: #243247;
  line-height: 1;
}

.lunar-sub {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #7F8CA4;
  letter-spacing: 2rpx;
}

.day-seal {
  min-width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  border: 2rpx dashed rgba(219, 162, 190, 0.52);
  background: rgba(251, 239, 245, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  transform: rotate(-15deg);
}

.day-seal text {
  color: #C08AA8;
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero-quote {
  display: block;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(223, 229, 240, 0.8);
  color: #697A95;
  font-size: 24rpx;
  font-family: "PingFang SC", "Songti SC", serif;
  line-height: 1.6;
}

.section-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 0 40rpx;
  margin-bottom: 24rpx;
}

.action-card {
  margin: 0;
  padding: 30rpx;
}

.section-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.mark {
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
  background: rgba(234, 244, 255, 0.9);
  color: #6E85A8;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mark.yi {
  background: rgba(234, 244, 255, 0.95);
  color: #6D89B0;
}
.mark.ji {
  background: rgba(251, 239, 245, 0.95);
  color: #BE89A8;
}
.mark.soft {
  background: rgba(243, 246, 251, 0.95);
  color: #8291A8;
}

.section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #243247;
}

.section-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #93A0B5;
  font-size: 22rpx;
  line-height: 1.4;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 10rpx 18rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tag.yi-tag {
  background: rgba(234, 244, 255, 0.9);
  color: #6D89B0;
}
.tag.ji-tag {
  background: rgba(251, 239, 245, 0.9);
  color: #BE89A8;
}

.modern-card,
.history-card {
  padding: 34rpx 36rpx;
}

.history-card {
  padding-bottom: 22rpx;
}

.history-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(228, 235, 246, 0.92);
}

.history-item:first-of-type {
  border-top: none;
}

.history-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D8B7C8, #B7CAD8);
  margin-top: 16rpx;
  flex-shrink: 0;
}

.history-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.history-tag {
  align-self: flex-start;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(243, 246, 251, 0.95);
  color: #8190A5;
  font-size: 20rpx;
  letter-spacing: 1rpx;
}

.history-text {
  color: #4D5D76;
  font-size: 24rpx;
  line-height: 1.7;
}

.modern-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(228, 235, 246, 0.92);
}

.modern-row:first-of-type {
  border-top: none;
}

.modern-label {
  color: #6D89B0;
  font-size: 24rpx;
  font-weight: 700;
}

.modern-label.avoid {
  color: #BE89A8;
}

.modern-text {
  flex: 1;
  color: #6C7C95;
  font-size: 24rpx;
  line-height: 1.5;
}

/* 历史事件加载中 */
.history-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 30rpx 0;
}

.history-loading-dot {
  font-size: 40rpx;
  color: #96A3B7;
  animation: dot-pulse 1.4s ease-in-out infinite;
}

.history-loading-dot:nth-child(2) { animation-delay: 0.2s; }
.history-loading-dot:nth-child(3) { animation-delay: 0.4s; }

.history-loading-text {
  font-size: 24rpx;
  color: #AFA699;
  margin-left: 10rpx;
  letter-spacing: 1rpx;
}

@keyframes dot-pulse {
  0%, 80%, 100% { opacity: 0.3; transform: translateY(0); }
  40% { opacity: 1; transform: translateY(-6rpx); }
}

.page-note {
  padding: 12rpx 54rpx 0;
  color: #AFA699;
  font-size: 22rpx;
  line-height: 1.5;
  text-align: center;
}

.bottom-space {
  height: 80rpx;
}

/* ===== 🌟 今日签语盒模块 ===== */
.fortune-card {
  margin: 0 40rpx 24rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(228, 235, 246, 0.92);
  border-radius: 36rpx;
  box-shadow: 0 16rpx 38rpx rgba(83, 99, 129, 0.05);
  padding: 34rpx 36rpx;
}

.fortune-unopened {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0 10rpx;
  transition: opacity 0.3s ease;
}

.fortune-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
  filter: drop-shadow(0 8rpx 16rpx rgba(0,0,0,0.06));
}

.fortune-hint {
  font-size: 22rpx;
  color: #8090A6;
  letter-spacing: 4rpx;
  font-family: "PingFang SC", "Songti SC", serif;
}

.shake {
  animation: shake-anim 0.35s ease-in-out infinite;
}

@keyframes shake-anim {
  0%, 100% { transform: rotate(0deg) scale(1); }
  25% { transform: rotate(-20deg) scale(1.1); }
  75% { transform: rotate(20deg) scale(1.1); }
}

.fortune-result {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 10rpx 0;
  animation: fade-in 0.6s ease-out forwards;
}

@keyframes fade-in {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fortune-level {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
  border: 2rpx solid currentColor;
  letter-spacing: 2rpx;
}

.fortune-level.best { color: #BE89A8; background: rgba(251, 239, 245, 0.92); }
.fortune-level.good { color: #8BA0C2; background: rgba(234, 244, 255, 0.92); }
.fortune-level.mid { color: #6D89B0; background: rgba(234, 244, 255, 0.92); }
.fortune-level.small { color: #8E9BB0; background: rgba(243, 246, 251, 0.92); }
.fortune-level.normal { color: #8E9BB0; background: rgba(243, 246, 251, 0.92); }

.fortune-text-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.fortune-keyword {
  font-size: 30rpx;
  font-weight: 600;
  color: #243247;
  margin-left: -12rpx;
}

.fortune-desc {
  font-size: 22rpx;
  color: #6C7C95;
  line-height: 1.6;
}
.history-empty { padding: 40rpx 0; text-align: center; }
.history-empty-text { font-size: 26rpx; color: #9C8C82; }

<!-- pages/almanac/almanac.wxml - 现代每日黄历 -->

<view class="almanac-page">
  <view class="almanac-nav" style="height: {{totalTopHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="nav-row" style="height: {{navBarHeight}}px;">
      <view class="back-btn" bindtap="goBack">
        <view class="back-btn-icon"></view>
      </view>
      <view class="nav-title">NO FORGET</view>
      <view class="nav-space"></view>
    </view>
  </view>

  <scroll-view scroll-y class="almanac-scroll">
    <view style="height: {{totalTopHeight + 18}}px;"></view>

    <view class="hero-card">
      <view class="hero-topline">
        <text>{{almanac.week}}</text>
        <text>{{almanac.solarIso}}</text>
      </view>
      <view class="hero-main">
        <view>
          <text class="lunar-title">{{almanac.lunarFull}}</text>
          <text class="lunar-sub">{{almanac.yearGanZhi}}年 · {{almanac.monthGanZhi}}月 · {{almanac.dayGanZhi}}日</text>
        </view>
      </view>
      <text class="hero-quote">" {{almanac.quote}} "</text>
    </view>

    <view class="section-grid">
      <view class="action-card yi-card">
        <view class="section-head">
          <text class="mark yi">宜</text>
          <text class="section-title">传统之宜</text>
        </view>
        <view class="tag-list">
          <block wx:for="{{almanac.yi}}" wx:key="*this">
            <text class="tag yi-tag">{{item}}</text>
          </block>
        </view>
      </view>

      <view class="action-card ji-card">
        <view class="section-head">
          <text class="mark ji">忌</text>
          <text class="section-title">传统之忌</text>
        </view>
        <view class="tag-list">
          <block wx:for="{{almanac.ji}}" wx:key="*this">
            <text class="tag ji-tag">{{item}}</text>
          </block>
        </view>
      </view>
    </view>

    <view class="fortune-card">
      <view class="section-head">
        <text class="mark soft">签</text>
        <text class="section-title">今日签语盒</text>
      </view>

      <view class="fortune-unopened" wx:if="{{fortuneState === 0}}" bindtap="drawFortune">
        <view class="fortune-icon">🥠</view>
        <text class="fortune-hint">点此获取今日签语</text>
      </view>

      <view class="fortune-unopened" wx:elif="{{fortuneState === 1}}">
        <view class="fortune-icon shake">🥠</view>
        <text class="fortune-hint">命运正在洗牌...</text>
      </view>

      <view class="fortune-result" wx:else>
        <view class="fortune-level {{fortuneResult.colorClass}}">{{fortuneResult.level}}</view>
        <view class="fortune-text-wrap">
          <text class="fortune-keyword">「{{fortuneResult.keyword}}」</text>
          <text class="fortune-desc">{{fortuneResult.desc}}</text>
        </view>
      </view>
    </view>

    <view class="modern-card">
      <view class="section-head">
        <text class="section-title">现代版提示</text>
      </view>
      <view class="modern-row">
        <text class="modern-label">宜</text>
        <text class="modern-text">{{almanac.modernYiText}}</text>
      </view>
      <view class="modern-row">
        <text class="modern-label avoid">忌</text>
        <text class="modern-text">{{almanac.modernJiText}}</text>
      </view>
    </view>

    <view class="history-card">
      <view class="section-head">
        <text class="mark soft">史</text>
        <view>
          <text class="section-title">历史上的今天</text>
          <text class="section-subtitle">同一个日期，也曾被这些故事标记</text>
        </view>
      </view>
      <view wx:if="{{historyLoading}}" class="history-loading">
        <text class="history-loading-dot">·</text>
        <text class="history-loading-dot">·</text>
        <text class="history-loading-dot">·</text>
        <text class="history-loading-text">正在获取真实历史事件</text>
      </view>
      <block wx:else>
        <view wx:if="{{almanac.history.length === 0}}" class="history-empty">
          <text class="history-empty-text">今天暂无收录的历史事件</text>
        </view>
        <block wx:else>
          <view wx:for="{{almanac.history}}" wx:key="displayText" class="history-item">
            <view class="history-dot"></view>
            <view class="history-copy">
              <text class="history-tag">{{item.categoryLabel}}</text>
              <text class="history-text">{{item.displayText}}</text>
            </view>
          </view>
        </block>
      </block>
    </view>

    <view class="page-note">黄历数据基于本地农历算法按系统日期生成，现代提示仅作生活参考。</view>
    <view class="bottom-space"></view>
  </scroll-view>
</view>

.tab-bar-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
  background:
    radial-gradient(circle at 16% 100%, rgba(251, 239, 245, 0.32), transparent 44%),
    radial-gradient(circle at 84% 100%, rgba(234, 244, 255, 0.3), transparent 42%),
    linear-gradient(180deg, rgba(247, 249, 254, 0), rgba(247, 249, 254, 0.84) 26%, rgba(247, 249, 254, 0.96) 100%);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

.tab-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 76rpx;
  padding: 0 86rpx;
  background: transparent;
  border-top: 1rpx solid rgba(190, 203, 223, 0.26);
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 76rpx;
  opacity: 0.62;
  transition: opacity 0.2s;
}

.tab-item.active {
  opacity: 1;
}

.tab-item-create {
  transform: translateY(-1rpx);
}

.tab-icon {
  width: 56rpx;
  height: 56rpx;
}

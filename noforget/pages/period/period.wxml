<view class="period-page">

  <view class="period-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-side nav-side-left" bindtap="goBack">
      <image class="period-nav-icon" src="/static/icons/system/back.svg" mode="aspectFit"></image>
    </view>
    <text class="nav-title">NO FORGET</text>
    <view class="nav-side nav-side-right" bindtap="goSettings">
      <image class="period-nav-icon" src="/static/icons/system/bell.svg" mode="aspectFit"></image>
    </view>
  </view>

  <view style="height: {{totalTopHeight}}px; width: 100%;"></view>

  <view class="period-content">
    <view class="status-card">
      <view class="status-label">下个周期</view>
      <view class="status-number-row">
        <text class="status-number">{{statusInfo.headlineNumber !== null ? statusInfo.headlineNumber : '—'}}</text>
        <text class="status-unit">天</text>
      </view>

      <view class="status-progress-info" wx:if="{{statusInfo.daysInfo || statusInfo.progress !== null}}">
        <text class="status-cycle-day">{{statusInfo.daysInfo || statusInfo.headlineHint || statusInfo.subLabel || '正在记录中'}}</text>
        <text class="status-progress-value">{{statusInfo.progress !== null ? (statusInfo.progress + '%') : ''}}</text>
      </view>
      <view class="status-progress" wx:if="{{statusInfo.progress !== null}}">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{statusInfo.progress}}%;"></view>
        </view>
      </view>

      <view class="period-toggle-row">
        <text class="period-toggle-label">姨妈来了</text>
        <view class="period-toggle-btn {{isPeriodDay ? 'active' : ''}}" bindtap="togglePeriodStatus">
          <view class="toggle-knob"></view>
        </view>
      </view>
    </view>

    <view class="summary-row" wx:if="{{summaryCards.length && statusInfo.hasData}}">
      <view class="summary-item summary-card summary-tone-{{item.tone}}" wx:for="{{summaryCards}}" wx:key="key">
        <image class="summary-icon-glyph summary-icon-image" src="{{item.iconPath}}" mode="aspectFit"></image>
        <text class="summary-title">{{item.titleCn}}</text>
        <text class="summary-caption">{{item.titleEn}}</text>
        <text class="summary-value">{{item.value}}</text>
      </view>
    </view>

    <view class="calendar-section">
      <view class="calendar-header">
        <view class="cal-nav-btn" bindtap="prevMonth">
          <view class="cal-arrow cal-arrow-left"></view>
        </view>
        <text class="cal-month-label">{{currentYear}}年{{currentMonth}}月</text>
        <view class="cal-nav-btn" bindtap="nextMonth">
          <view class="cal-arrow cal-arrow-right"></view>
        </view>
      </view>

      <view class="calendar-weekday">
        <text wx:for="{{weekdays}}" wx:key="index" class="weekday-text">{{item}}</text>
      </view>

      <view class="calendar-grid">
        <view
          wx:for="{{calendarCells}}"
          wx:key="date"
          class="date-cell {{item.empty ? 'empty' : ''}} {{item.isToday ? 'today' : ''}} {{item.phase ? 'phase-' + item.phase.key : ''}}"
          bindtap="onDateTap"
          data-date="{{item.date}}"
        >
          <text class="date-day">{{item.day}}</text>
        </view>
      </view>

      <view class="calendar-legend">
        <view class="legend-item" wx:for="{{phaseLegend}}" wx:key="key">
          <view class="legend-color" style="background: {{item.color}};"></view>
          <text class="legend-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="quick-actions" wx:if="{{statusInfo.hasData}}">
      <view class="action-btn" bindtap="showPeriodStartModal">
        <view class="action-circle">
          <image class="action-icon-image" src="/static/icons/system/play.svg" mode="aspectFit"></image>
        </view>
        <text class="action-btn-text">开始</text>
      </view>
      <view class="action-btn" bindtap="showPeriodEndModal">
        <view class="action-circle">
          <image class="action-icon-image" src="/static/icons/system/stop.svg" mode="aspectFit"></image>
        </view>
        <text class="action-btn-text">结束</text>
      </view>
      <view class="action-btn" bindtap="goStats">
        <view class="action-circle">
          <image class="action-icon-image" src="/static/icons/system/stats.svg" mode="aspectFit"></image>
        </view>
        <text class="action-btn-text">统计</text>
      </view>
      <view class="action-btn" bindtap="deleteCurrentPeriod">
        <view class="action-circle danger">
          <image class="action-icon-image" src="/static/icons/system/trash.svg" mode="aspectFit"></image>
        </view>
        <text class="action-btn-text">删除</text>
      </view>
    </view>

    <view class="empty-guide" wx:if="{{!statusInfo.hasData}}">
      <text class="empty-guide-title">开始记录你的姨妈</text>
      <text class="empty-guide-desc">从第一次记录开始，系统会帮你整理周期变化</text>
      <view class="action-btn-primary-large" bindtap="showPeriodStartModal">
        <text class="action-btn-text">记录开始日</text>
      </view>
    </view>
  </view>

  <tab-bar active="index"></tab-bar>

  <view class="modal-overlay {{showPeriodModal ? 'show' : ''}}" bindtap="hidePeriodModal" wx:if="{{showPeriodModal}}">
    <view class="modal-sheet" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">开始日</text>
        <text class="modal-close" bindtap="hidePeriodModal">×</text>
      </view>
      <view class="modal-body">
        <text class="input-label">选择日期</text>
        <picker mode="date" value="{{periodDate}}" bindchange="onPeriodDateChange">
          <view class="date-picker-display">
            <text>{{periodDate || '请选择日期'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="modal-footer">
        <view class="modal-btn primary" bindtap="savePeriodStart">
          <text>保存并开始追踪</text>
        </view>
      </view>
    </view>
  </view>

  <view class="modal-overlay {{showPeriodEndModal ? 'show' : ''}}" bindtap="hidePeriodEndModal" wx:if="{{showPeriodEndModal}}">
    <view class="modal-sheet" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">结束日</text>
        <text class="modal-close" bindtap="hidePeriodEndModal">×</text>
      </view>
      <view class="modal-body">
        <text class="input-label">选择姨妈结束日期</text>
        <picker mode="date" value="{{periodEndDate}}" bindchange="onPeriodEndDateChange">
          <view class="date-picker-display">
            <text>{{periodEndDate || '请选择日期'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="modal-footer">
        <view class="modal-btn primary" bindtap="savePeriodEnd">
          <text>保存结束日</text>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-sheet-overlay {{showSheet ? 'show' : ''}}" bindtap="closeSheet">
    <view class="bottom-sheet-content" catchtap="stopPropagation">
      <view class="sheet-header">
        <view class="sheet-date-wrap">
          <text class="sheet-date-label">记录日期</text>
          <picker mode="date" value="{{logDate}}" bindchange="onLogDateChange">
            <view class="sheet-date-btn">
              <text>{{logDate || '选择日期'}}</text>
              <text class="sheet-date-arrow">›</text>
            </view>
          </picker>
        </view>
        <text class="sheet-close-btn" bindtap="closeSheet">完成</text>
      </view>

      <view class="sheet-section">
        <view class="sheet-row" bindtap="openSheet" data-type="flow">
          <view class="sheet-row-left">
            <text class="sheet-row-label">经量</text>
            <text class="sheet-row-value">{{flowLabel || '未记录'}}</text>
          </view>
          <text class="sheet-row-arrow">›</text>
        </view>

        <view class="sheet-row" bindtap="openSheet" data-type="pain">
          <view class="sheet-row-left">
            <text class="sheet-row-label">痛经</text>
            <text class="sheet-row-value">{{painLabel || '未记录'}}</text>
          </view>
          <text class="sheet-row-arrow">›</text>
        </view>

        <view class="sheet-row" bindtap="openSheet" data-type="symptoms">
          <view class="sheet-row-left">
            <text class="sheet-row-label">身体状态</text>
            <text class="sheet-row-value">{{symptomsLabel || '未记录'}}</text>
          </view>
          <text class="sheet-row-arrow">›</text>
        </view>

        <view class="sheet-row" bindtap="openSheet" data-type="mood">
          <view class="sheet-row-left">
            <text class="sheet-row-label">情绪</text>
            <text class="sheet-row-value">{{moodLabel || '未记录'}}</text>
          </view>
          <text class="sheet-row-arrow">›</text>
        </view>
      </view>

      <view class="sheet-options" wx:if="{{sheetType}}">
        <view class="sheet-options-header">
          <text class="sheet-options-title">{{sheetTitle}}</text>
          <text class="sheet-options-close" bindtap="closeSheetOptions">×</text>
        </view>
        <view class="pill-group">
          <view
            wx:for="{{currentOptions}}"
            wx:key="key"
            class="pill-btn {{item.selected ? 'active' : ''}}"
            bindtap="handleOptionSelect"
            data-key="{{item.key}}"
          >{{item.label}}</view>
        </view>
      </view>

      <view class="sheet-notes">
        <textarea
          class="notes-textarea"
          placeholder="还有什么想记录的..."
          value="{{logData.notes}}"
          bindinput="setNotes"
          maxlength="200"
        ></textarea>
      </view>
    </view>
  </view>

</view>

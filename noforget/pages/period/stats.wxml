<view class="stats-page">
  <view class="page-fixed-bg"></view>

  <view class="period-nav" style="height: {{totalTopHeight}}px; padding-top: {{statusBarHeight}}px; box-sizing: border-box;">
    <view class="nav-content" style="height: {{navBarHeight}}px;">
      <view class="nav-left" bindtap="goBack"><image class="stats-nav-icon" src="/static/icons/system/back.svg" mode="aspectFit"></image></view>
      <text class="nav-title">{{navTitle}}</text>
      <view class="nav-right"></view>
    </view>
  </view>

  <scroll-view class="stats-body" scroll-y>
    <view style="height: {{totalTopHeight + 16}}px;"></view>

    <view class="stats-overview" wx:if="{{stats}}">
      <view class="stats-kicker-card">
        <view class="kicker-copy">
          <text class="kicker-label">周期档案</text>
          <text class="kicker-title">把每一次变化，变成更懂自己的线索</text>
          <text class="kicker-desc">{{trendSummary.sampleLabel}} · {{trendSummary.variabilityLabel}} · {{trendSummary.bleedLabel}}</text>
        </view>
      </view>

      <view class="overview-card">
        <view class="stat-item">
          <text class="stat-value">{{stats.avgCycle}}<text class="stat-unit">天</text></text>
          <text class="stat-label">平均间隔</text>
        </view>
        <view class="stat-divider-h"></view>
        <view class="stat-item">
          <text class="stat-value">{{avgPeriodLength || 5}}<text class="stat-unit">天</text></text>
          <text class="stat-label">平均见红天数</text>
        </view>
      </view>

      <view class="stat-secondary">
        <view class="stat-item">
          <text class="stat-mini-val">{{stats.minCycle}}</text>
          <text class="stat-mini-label">最短</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-mini-val">{{stats.maxCycle}}</text>
          <text class="stat-mini-label">最长</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-mini-val">{{stats.dataPoints}}</text>
          <text class="stat-mini-label">间隔数</text>
        </view>
      </view>

      <view class="stable-badge {{stableBadge.status}}">
        <view class="stable-badge-icon {{stableBadge.status}}">
          <image wx:if="{{stableBadge.status === 'stable'}}" class="stable-state-icon" src="/static/icons/system/check.svg" mode="aspectFit"></image>
          <image wx:else class="stable-state-icon" src="/static/icons/system/wave.svg" mode="aspectFit"></image>
        </view>
        <view class="stable-badge-copy">
          <text class="stable-badge-title">{{stableBadge.text}}</text>
          <text class="stable-badge-desc">{{stableBadge.desc}}</text>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{!stats}}">
      <text class="empty-icon">🌸</text>
      <text class="empty-title">还没有记录</text>
      <text class="empty-desc">记录满一个完整间隔后
这里就会出现温暖的曲线</text>
    </view>

    <view class="chart-section" wx:if="{{recentCycles.length > 0}}">
      <canvas canvas-id="intervalChart" class="chart-canvas" style="width: {{canvasWidth}}px; height: 320px;"></canvas>
      <view class="stats-card">
        <view class="card-title-row">
          <text class="card-title">近 {{recentCycles.length}} 个间隔趋势</text>
          <text class="card-title-meta">{{trendSummary.driftLabel}}</text>
        </view>
        <view class="bar-chart">
          <view wx:for="{{recentCycles}}" wx:key="startDate" wx:for-index="index" class="bar-row">
            <text class="bar-label">{{item.start}}</text>
            <view class="bar-track">
              <view class="bar-fill" style="width: {{(item.length / 40) * 100}}%; background: {{item.stable ? '#D8C7EC' : '#F2C8B8'}};"></view>
            </view>
            <text class="bar-val">{{item.length}}天</text>
          </view>
        </view>
        <view class="chart-legend">
          <view class="legend-item"><view class="legend-dot" style="background:#D8C7EC;"></view><text class="legend-label">稳定</text></view>
          <view class="legend-item"><view class="legend-dot" style="background:#F2C8B8;"></view><text class="legend-label">波动</text></view>
        </view>
      </view>
    </view>

    <view class="history-section" wx:if="{{historyRows.length > 0}}">
      <view class="stats-card">
        <view class="card-title-row">
          <text class="card-title">最近记录拆解</text>
          <text class="card-title-meta">{{historyRows.length}} 条样本</text>
        </view>
        <view class="history-list">
          <view wx:for="{{historyRows}}" wx:key="startDate" class="history-row">
            <view class="history-dot" style="background:{{item.stable ? '#D8C7EC' : '#F2C8B8'}};"></view>
            <view class="history-info">
              <text class="history-date">{{item.start}} ~ {{item.end}}</text>
              <text class="history-cycle">{{item.length}} 天 · {{item.variation}}</text>
            </view>
            <view class="history-status {{item.tagClass}}">
              <image wx:if="{{item.tagClass === 'stable'}}" class="history-status-icon" src="/static/icons/system/check.svg" mode="aspectFit"></image>
              <image wx:else class="history-status-icon" src="/static/icons/system/wave.svg" mode="aspectFit"></image>
              <text>{{item.statusText}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="insight-section" wx:if="{{stats}}">
      <view class="insight-pill-grid">
        <view class="insight-pill-card" wx:for="{{insightCards}}" wx:key="key">
          <view class="insight-pill-head">
            <text class="insight-pill-icon">{{item.icon}}</text>
            <text class="insight-pill-title">{{item.title}}</text>
          </view>
          <text class="insight-pill-metric">{{item.metric}}</text>
          <text class="insight-pill-caption">{{item.caption}}</text>
          <text class="insight-pill-desc">{{item.desc}}</text>
        </view>
      </view>

      <view class="stats-card insight-card">
        <text class="insight-label">💡 数据洞察</text>
        <text class="insight-text">{{insightText}}</text>
      </view>
    </view>
  </scroll-view>
</view>

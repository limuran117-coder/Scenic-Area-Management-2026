page {
  background: #f7f9fe;
  color: #243247;
}

.period-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 10% 14%, rgba(251, 207, 222, 0.62) 0, rgba(251, 207, 222, 0) 36%),
    radial-gradient(circle at 86% 10%, rgba(174, 231, 222, 0.46) 0, rgba(174, 231, 222, 0) 38%),
    radial-gradient(circle at 76% 76%, rgba(205, 231, 255, 0.42) 0, rgba(205, 231, 255, 0) 38%),
    radial-gradient(circle at 20% 88%, rgba(239, 225, 169, 0.24) 0, rgba(239, 225, 169, 0) 40%),
    radial-gradient(circle at 48% 42%, rgba(255, 255, 255, 0.5) 0, rgba(255, 255, 255, 0) 44%),
    #f7f9fe;
  background-size: 146% 146%;
  animation: period-mist-drift 18s ease-in-out infinite alternate;
}

@keyframes period-mist-drift {
  0% { background-position: 4% 0%; }
  100% { background-position: 96% 100%; }
}

.period-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  background: rgba(247, 249, 254, 0.58);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.66);
}

.nav-side {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 38rpx;
  font-weight: 600;
  color: #243247;
  letter-spacing: 6rpx;
}

.period-nav-icon {
  width: 40rpx;
  height: 40rpx;
}

.period-content {
  padding: 36rpx 32rpx calc(188rpx + env(safe-area-inset-bottom, 0));
}


.status-card,
.calendar-section,
.summary-item,
.action-circle,
.empty-guide,
.modal-sheet,
.bottom-sheet-content {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(22px);
  -webkit-backdrop-filter: blur(22px);
  border: 1rpx solid rgba(228, 235, 246, 0.92);
  box-shadow: 0 18rpx 44rpx rgba(83, 99, 129, 0.06);
}

.status-card {
  padding: 34rpx 34rpx 34rpx;
  border-radius: 38rpx;
}

.status-label {
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: #B387A1;
  margin-bottom: 20rpx;
}

.status-number-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.status-number {
  font-size: 92rpx;
  font-weight: 700;
  line-height: 0.95;
  color: #243247;
}

.status-unit {
  font-size: 34rpx;
  color: #7A8AA2;
}

.status-progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
  font-size: 17rpx;
  color: #72839C;
}

.status-progress {
  margin-bottom: 40rpx;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(230, 236, 246, 0.92);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #E9BFD4 0%, #B7D5F3 100%);
}

.period-toggle-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.period-toggle-label {
  font-size: 24rpx;
  color: #243247;
}

.period-toggle-btn {
  width: 88rpx;
  height: 50rpx;
  border-radius: 999rpx;
  background: rgba(237, 241, 247, 0.92);
  padding: 4rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.period-toggle-btn.active {
  background: linear-gradient(135deg, #98B5D9 0%, #DAB4C8 100%);
}

.toggle-knob {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.2s ease;
}

.period-toggle-btn.active .toggle-knob {
  transform: translateX(38rpx);
}

.summary-row {
  display: flex;
  gap: 18rpx;
  margin: 24rpx 0 34rpx;
}

.summary-item {
  flex: 1;
  border-radius: 28rpx;
  padding: 22rpx 14rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  min-height: 168rpx;
}

.summary-card {
  background:
    linear-gradient(180deg, rgba(255,255,255,0.88), rgba(249,251,255,0.8)),
    radial-gradient(circle at 50% 0%, rgba(234,244,255,0.42), transparent 62%);
}

.summary-tone-rose {
  background:
    linear-gradient(180deg, rgba(255,255,255,0.92), rgba(252,246,249,0.82)),
    radial-gradient(circle at 50% 0%, rgba(245, 220, 232, 0.6), transparent 68%);
}

.summary-tone-blue {
  background:
    linear-gradient(180deg, rgba(255,255,255,0.92), rgba(245,249,255,0.82)),
    radial-gradient(circle at 50% 0%, rgba(220, 234, 254, 0.65), transparent 68%);
}

.summary-tone-gold {
  background:
    linear-gradient(180deg, rgba(255,255,255,0.92), rgba(253,250,242,0.82)),
    radial-gradient(circle at 50% 0%, rgba(247, 239, 207, 0.72), transparent 68%);
}

.summary-title {
  font-size: 21rpx;
  line-height: 1.15;
  color: #5F708B;
}

.summary-caption {
  font-size: 15rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: #A7B3C4;
}

.summary-icon-glyph {
  width: 54rpx;
  height: 54rpx;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #243247;
  text-align: center;
  line-height: 1.35;
  margin-top: 6rpx;
}

.summary-tone-rose .summary-title {
  color: #B7869D;
}

.summary-tone-rose .summary-caption {
  color: #C6A7B6;
}

.summary-tone-blue .summary-title {
  color: #7C97BF;
}

.summary-tone-blue .summary-caption {
  color: #A4B5D2;
}

.summary-tone-gold .summary-title {
  color: #AD9155;
}

.summary-tone-gold .summary-caption {
  color: #C7AF79;
}

.calendar-section {
  border-radius: 36rpx;
  padding: 28rpx 28rpx 30rpx;
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.cal-nav-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cal-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 2.6rpx solid #7F8FA6;
  border-left: 2.6rpx solid #7F8FA6;
}

.cal-arrow-left {
  transform: rotate(-45deg);
}

.cal-arrow-right {
  transform: rotate(135deg);
}

.cal-month-label {
  font-size: 52rpx;
  font-weight: 700;
  color: #243247;
}

.calendar-weekday {
  display: flex;
  margin-bottom: 24rpx;
}

.weekday-text {
  flex: 1;
  text-align: center;
  font-size: 20rpx;
  color: #96A3B7;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  row-gap: 14rpx;
}

.date-cell {
  width: calc((100% - 24rpx) / 7);
  height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 22rpx;
  transition: background 0.18s ease, box-shadow 0.18s ease;
}

.date-cell.empty {
  opacity: 0;
}

.date-day {
  font-size: 24rpx;
  color: #243247;
}

.date-cell.today {
  background: rgba(234, 244, 255, 0.96);
  box-shadow: inset 0 0 0 2rpx rgba(151, 174, 208, 0.4);
}

.date-cell.phase-menstruate {
  background: #F5DCE8;
}

.date-cell.phase-ovulation {
  background: #DCEAFE;
}

.date-cell.phase-fertile {
  background: #F7EFCF;
}

.date-cell.phase-follicular,
.date-cell.phase-luteal {
  background: #E3F1E1;
}

.calendar-legend {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 18rpx 22rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(228, 235, 246, 0.92);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-color {
  width: 18rpx;
  height: 18rpx;
  border-radius: 8rpx;
  box-shadow: inset 0 0 0 1rpx rgba(255,255,255,0.85);
}

.legend-label {
  font-size: 20rpx;
  color: #7A8AA2;
}

.quick-actions {
  margin: 34rpx 12rpx 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.action-btn {
  width: 23%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.action-circle {
  width: 104rpx;
  height: 104rpx;
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.9), rgba(246,249,255,0.78)),
    radial-gradient(circle at 30% 20%, rgba(234, 244, 255, 0.62), transparent 58%);
}

.action-btn:nth-child(2) .action-circle {
  background:
    linear-gradient(180deg, rgba(255,255,255,0.92), rgba(251,245,249,0.8)),
    radial-gradient(circle at 30% 20%, rgba(245, 220, 232, 0.62), transparent 58%);
}

.action-btn:nth-child(3) .action-circle {
  background:
    linear-gradient(180deg, rgba(255,255,255,0.92), rgba(245,249,255,0.8)),
    radial-gradient(circle at 30% 20%, rgba(220, 234, 254, 0.65), transparent 58%);
}

.action-circle.danger {
  background:
    linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,246,244,0.82)),
    radial-gradient(circle at 30% 20%, rgba(250, 224, 218, 0.7), transparent 60%);
}

.action-icon-image {
  width: 58rpx;
  height: 58rpx;
}

.action-btn-text {
  font-size: 22rpx;
  color: #5D6E88;
}

.action-btn:nth-child(2) .action-btn-text {
  color: #B7879E;
}

.action-btn:nth-child(3) .action-btn-text {
  color: #7C97BF;
}

.action-btn:nth-child(4) .action-btn-text {
  color: #C47D72;
}

.empty-guide {
  margin-top: 26rpx;
  padding: 42rpx 28rpx;
  border-radius: 36rpx;
  text-align: center;
}

.empty-guide-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #141614;
  margin-bottom: 14rpx;
}

.empty-guide-desc {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: #717171;
  margin-bottom: 26rpx;
}

.action-btn-primary-large {
  height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #98B5D9 0%, #DAB4C8 100%);
  color: #fff;
  box-shadow: 0 16rpx 34rpx rgba(151, 171, 208, 0.22);
}

.modal-overlay,
.bottom-sheet-overlay {
  position: fixed;
  inset: 0;
  background: rgba(18, 18, 18, 0.22);
  z-index: 1600;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.24s ease;
}

.modal-overlay.show,
.bottom-sheet-overlay.show {
  opacity: 1;
  visibility: visible;
}

.modal-sheet,
.bottom-sheet-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 34rpx 34rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.24s ease;
}

.modal-overlay.show .modal-sheet,
.bottom-sheet-overlay.show .bottom-sheet-content {
  transform: translateY(0);
}

.modal-sheet {
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom, 0));
}

.bottom-sheet-content {
  padding: 28rpx 30rpx calc(32rpx + env(safe-area-inset-bottom, 0));
}

.modal-header,
.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-header {
  padding: 30rpx 30rpx 18rpx;
}

.modal-title,
.sheet-options-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #151715;
}

.modal-close,
.sheet-options-close {
  font-size: 42rpx;
  color: #8a8a8a;
}

.modal-body {
  padding: 16rpx 30rpx 10rpx;
}

.modal-footer {
  padding: 18rpx 30rpx 0;
}

.input-label,
.sheet-date-label {
  font-size: 22rpx;
  color: #7d7d7d;
  margin-bottom: 12rpx;
}

.date-picker-display,
.sheet-section,
.sheet-options,
.notes-textarea {
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(228, 235, 246, 0.92);
  box-shadow: 0 12rpx 28rpx rgba(83, 99, 129, 0.06);
}

.date-picker-display {
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #243247;
}

.picker-arrow,
.sheet-date-arrow,
.sheet-row-arrow {
  color: #8b8b8b;
}

.modal-btn.primary {
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #98B5D9 0%, #DAB4C8 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.sheet-header {
  margin-bottom: 20rpx;
}

.sheet-date-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #171917;
  font-weight: 600;
}

.sheet-close-btn {
  font-size: 26rpx;
  color: #7D96BA;
}

.sheet-section {
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
}

.sheet-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid rgba(233, 233, 233, 0.72);
}

.sheet-row:last-child {
  border-bottom: none;
}

.sheet-row-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.sheet-row-label {
  font-size: 28rpx;
  color: #243247;
  font-weight: 600;
}

.sheet-row-value {
  font-size: 24rpx;
  color: #7b7b7b;
}

.sheet-options {
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.pill-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pill-btn {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
  color: #6c6c6c;
  border: 1rpx solid rgba(245, 245, 245, 0.7);
}

.pill-btn.active {
  background: linear-gradient(135deg, #98B5D9 0%, #DAB4C8 100%);
  color: #fff;
}

.notes-textarea {
  width: 100%;
  min-height: 120rpx;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #171917;
  box-sizing: border-box;
}

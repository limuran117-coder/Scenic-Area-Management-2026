/* pages/period/settings.wxss — LunaDay 治愈系 */
page {
  background:
    radial-gradient(circle at 12% 10%, rgba(251, 207, 222, 0.44) 0, rgba(251, 207, 222, 0) 38%),
    radial-gradient(circle at 88% 8%, rgba(205, 231, 255, 0.54) 0, rgba(205, 231, 255, 0) 36%),
    radial-gradient(circle at 76% 82%, rgba(174, 231, 222, 0.28) 0, rgba(174, 231, 222, 0) 40%),
    radial-gradient(circle at 20% 88%, rgba(239, 225, 169, 0.22) 0, rgba(239, 225, 169, 0) 38%),
    linear-gradient(180deg, #FAFCFF, #F7F9FE);
  background-size: 142% 142%;
  animation: settings-mist-drift 18s ease-in-out infinite alternate;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
  font-family: -apple-system, "PingFang SC", sans-serif;
  color: #243247;
}

@keyframes settings-mist-drift {
  0% { background-position: 8% 0%; }
  100% { background-position: 92% 100%; }
}

.period-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: rgba(247,249,254,0.72);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
}
.nav-left, .nav-right { width: 80rpx; }
.nav-left {
  display: flex;
  align-items: center;
}
.nav-arrow {
  position: relative;
  width: 40rpx;
  height: 40rpx;
}
.nav-arrow::before {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 9rpx;
  width: 16rpx;
  height: 16rpx;
  border-left: 2.6rpx solid #243247;
  border-bottom: 2.6rpx solid #243247;
  border-radius: 2rpx;
  transform: rotate(45deg);
}
.nav-title { font-size: 32rpx; font-weight: 600; color: #243247; text-align: center; flex: 1; }

.page-content { padding-top: 24rpx; }
.settings-body { padding: 0 0 100rpx; }

/* ─── 统一卡片样式 ─────────────────────────────── */
.settings-section { margin-bottom: 40rpx; }

.settings-group {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin: 0 32rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(214, 189, 232, 0.12);
}

.group-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4A3728;
  margin-bottom: 24rpx;
  display: block;
}

/* ─── 列表项布局 ─────────────────────────────── */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F7F5F9;
}
.setting-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.item-label {
  font-size: 30rpx;
  color: #4A3728;
}

/* ─── 多行平铺标签组 ─────────────────────────── */
.setting-item-column {
  display: flex;
  flex-direction: column;
}

.pill-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.pill-btn {
  flex: 0 0 calc(50% - 8rpx);
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  background: #F7F5F9;
  color: #7D7068;
  font-size: 28rpx;
  transition: all 0.2s;
}

.pill-btn.active {
  background: #D6BDE8;
  color: #FFFFFF;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(214, 189, 232, 0.25);
}

.setting-desc {
  font-size: 24rpx;
  color: #9C8C82;
  line-height: 1.5;
  margin-top: 8rpx;
}

/* ─── 兼容旧 class ─────────────────────────── */
.settings-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin: 0 32rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(214, 189, 232, 0.12);
}
.section-title {
  font-size: 26rpx;
  color: #9C8C82;
  font-weight: 500;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F7F5F9;
}
.setting-row:last-child { border-bottom: none; padding-bottom: 0; }
.setting-info { flex: 1; }
.setting-label { display: block; font-size: 30rpx; color: #4A3728; font-weight: 500; }
.setting-desc { display: block; font-size: 22rpx; color: #9C8C82; margin-top: 4rpx; }
.setting-value { font-size: 28rpx; color: #9C8C82; }
.setting-value.locked { color: #C2BCB4; }
.picker-btn {
  font-size: 28rpx;
  color: #9B7EC6;
  padding: 8rpx 16rpx;
  background: #F5F0FA;
  border-radius: 12rpx;
}
.privacy-note {
  padding: 20rpx 0;
  background: transparent;
  font-size: 22rpx;
  color: #9C8C82;
  line-height: 1.6;
}
.setting-row.danger .setting-label { color: #C04040; }

/* ─── 模式选择平铺 ─────────────────────────── */
.mode-pill-group { padding: 0; }
.mode-desc-row { padding: 16rpx 0 0; }
.mode-desc-text { font-size: 24rpx; color: #9C8C82; line-height: 1.6; }

/* 旧兼容 */
.mode-row {
  display: flex; align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F7F5F9;
}
.mode-row:last-child { border-bottom: none; }
.mode-row.active { background: transparent; }
.mode-radio {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  border: 3rpx solid #E8E0D8;
  display: flex; align-items: center; justify-content: center;
  margin-right: 16rpx; margin-top: 4rpx; flex-shrink: 0;
}
.mode-row.active .mode-radio { border-color: #D6BDE8; }
.radio-dot { width: 20rpx; height: 20rpx; border-radius: 50%; background: #D6BDE8; }
.mode-info { flex: 1; }
.mode-label { display: block; font-size: 30rpx; color: #4A3728; font-weight: 500; }
.mode-desc { display: block; font-size: 22rpx; color: #9C8C82; margin-top: 4rpx; }

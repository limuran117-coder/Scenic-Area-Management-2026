page {
  background: #f7f9fe;
  font-family: -apple-system, "PingFang SC", sans-serif;
  color: #243247;
}

.stats-page {
  min-height: 100vh;
  position: relative;
}

.page-fixed-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: -1;
  pointer-events: none;
  background:
    radial-gradient(circle at 6% 8%, rgba(205, 231, 255, 0.58), transparent 36%),
    radial-gradient(circle at 92% 18%, rgba(251, 207, 222, 0.5), transparent 38%),
    radial-gradient(circle at 18% 78%, rgba(174, 231, 222, 0.34), transparent 40%),
    radial-gradient(circle at 78% 88%, rgba(239, 225, 169, 0.28), transparent 38%),
    radial-gradient(circle at 50% 42%, rgba(255, 255, 255, 0.5), transparent 44%),
    linear-gradient(180deg, #fafcff, #f7f9fe);
  background-size: 142% 142%;
  animation: mist-drift 16s ease-in-out infinite alternate;
}

@keyframes mist-drift {
  0% { background-position: 0% 12%; }
  100% { background-position: 100% 88%; }
}

.period-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background: rgba(247, 249, 254, 0.72);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  position: relative;
  padding: 0 32rpx;
}

.nav-left,
.nav-right {
  width: 76rpx;
  height: 100%;
  flex-shrink: 0;
}

.nav-left {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.stats-nav-icon {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 38rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
  color: #243247;
}

.stats-body {
  height: 100vh;
  box-sizing: border-box;
  padding: 0 28rpx 116rpx;
}

.stats-kicker-card,
.overview-card,
.stat-secondary,
.stable-badge,
.stats-card,
.insight-pill-card {
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(22px);
  -webkit-backdrop-filter: blur(22px);
  border: 1rpx solid rgba(228, 235, 246, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(83, 99, 129, 0.06);
}

.stats-overview {
  margin-bottom: 22rpx;
}

.stats-kicker-card {
  border-radius: 34rpx;
  padding: 28rpx 28rpx 26rpx;
  margin-bottom: 16rpx;
}

.kicker-copy {
  display: flex;
  flex-direction: column;
}

.kicker-label {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: #8fa0b8;
  text-transform: uppercase;
}

.kicker-title {
  margin-top: 12rpx;
  font-size: 32rpx;
  line-height: 1.4;
  color: #243247;
  font-weight: 600;
}

.kicker-desc {
  margin-top: 14rpx;
  font-size: 21rpx;
  line-height: 1.55;
  color: #7f8ea7;
}

.overview-card {
  border-radius: 32rpx;
  padding: 38rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 14rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 60rpx;
  font-weight: 700;
  color: #9d85cc;
  line-height: 1;
}

.stat-unit {
  font-size: 24rpx;
  font-weight: normal;
  margin-left: 4rpx;
  color: #95a3b8;
}

.stat-label {
  font-size: 23rpx;
  color: #8d9bb0;
  margin-top: 10rpx;
}

.stat-divider-h {
  width: 2rpx;
  height: 60rpx;
  background: rgba(224, 231, 242, 0.92);
}

.stat-secondary {
  display: flex;
  border-radius: 30rpx;
  padding: 24rpx 18rpx;
  margin-bottom: 14rpx;
}

.stat-secondary .stat-item {
  flex: 1;
}

.stat-mini-val {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #8fa9d5;
}

.stat-mini-label {
  display: block;
  font-size: 21rpx;
  color: #8d9bb0;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  background: rgba(224, 231, 242, 0.92);
  margin: 0 8rpx;
}

.stable-badge {
  border-radius: 28rpx;
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.stable-badge-icon {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  position: relative;
  flex-shrink: 0;
}

.stable-badge-icon.stable {
  background: rgba(216, 241, 224, 0.88);
}

.stable-badge-icon.unstable {
  background: rgba(250, 232, 223, 0.92);
}

.stable-state-icon {
  width: 28rpx;
  height: 28rpx;
  position: absolute;
  left: 9rpx;
  top: 9rpx;
}

.stable-badge-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.stable-badge-title {
  font-size: 25rpx;
  color: #243247;
  font-weight: 600;
}

.stable-badge-desc {
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #8696ad;
  line-height: 1.5;
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 88rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #243247;
  margin-bottom: 12rpx;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  color: #8d9bb0;
  line-height: 1.7;
  white-space: pre-line;
}

.stats-card {
  border-radius: 32rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
}

.card-title-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 29rpx;
  font-weight: 600;
  color: #243247;
}

.card-title-meta {
  font-size: 19rpx;
  color: #96a4b9;
}

.bar-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.bar-row:last-child {
  margin-bottom: 0;
}

.bar-label {
  font-size: 19rpx;
  color: #8d9bb0;
  width: 110rpx;
  flex-shrink: 0;
}

.bar-track {
  flex: 1;
  height: 18rpx;
  background: rgba(239, 243, 250, 0.95);
  border-radius: 999rpx;
  overflow: hidden;
  margin: 0 12rpx;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
}

.bar-val {
  width: 64rpx;
  font-size: 21rpx;
  color: #55657f;
  text-align: right;
  flex-shrink: 0;
}

.chart-legend {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-top: 18rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.legend-label {
  font-size: 19rpx;
  color: #8d9bb0;
}

.history-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(235, 240, 248, 0.92);
}

.history-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.history-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.history-info {
  flex: 1;
}

.history-date {
  display: block;
  font-size: 25rpx;
  color: #243247;
  font-weight: 600;
}

.history-cycle {
  display: block;
  font-size: 20rpx;
  color: #8d9bb0;
  margin-top: 6rpx;
}

.history-status {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  flex-shrink: 0;
}

.history-status.stable {
  background: rgba(232, 245, 236, 0.96);
  color: #6b9a7f;
}

.history-status.unstable {
  background: rgba(255, 240, 232, 0.96);
  color: #c08364;
}

.history-status-icon {
  width: 20rpx;
  height: 20rpx;
  flex-shrink: 0;
}

.insight-section {
  margin-bottom: 40rpx;
}

.insight-pill-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.insight-pill-card {
  border-radius: 30rpx;
  padding: 24rpx 24rpx;
}

.insight-pill-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.insight-pill-icon {
  font-size: 26rpx;
  color: #8fa9d5;
}

.insight-pill-title {
  font-size: 23rpx;
  color: #6d7e98;
}

.insight-pill-metric {
  display: block;
  margin-top: 12rpx;
  font-size: 40rpx;
  line-height: 1;
  color: #243247;
  font-weight: 700;
}

.insight-pill-caption {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #8d9bb0;
}

.insight-pill-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 21rpx;
  line-height: 1.65;
  color: #667791;
}

.insight-card {
  background: linear-gradient(135deg, rgba(244, 239, 251, 0.92) 0%, rgba(235, 243, 255, 0.9) 100%);
}

.insight-label {
  display: block;
  font-size: 27rpx;
  font-weight: 600;
  color: #243247;
  margin-bottom: 12rpx;
}

.insight-text {
  font-size: 24rpx;
  color: #4f617b;
  line-height: 1.75;
}

.chart-canvas { width: 100%; display: block; margin-bottom: 16rpx; }

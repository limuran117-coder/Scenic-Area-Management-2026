<view class="settings-page" >
  <view class="period-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-left" bindtap="goBack"><view class="nav-arrow"></view></view>
    <text class="nav-title">🌸 隐私与提醒</text>
    <view class="nav-right"></view>
  </view>

  <view style="height: {{totalTopHeight}}px; width: 100%;"></view>

  <view class="settings-body" style="padding-top: 24rpx;">

    <!-- 云端同步（可选功能） -->
    <view class="settings-section">
      <view class="section-title">☁️ 云端同步</view>
      <view class="settings-card">
        <view class="setting-row">
          <view class="setting-info">
            <text class="setting-label">自动同步</text>
            <text class="setting-desc">{{cloudEnabled ? '记录后自动同步至云端' : '当前未连接云端，可重新开启'}}</text>
          </view>
          <switch checked="{{cloudEnabled}}" bindchange="toggleCloudSync" color="#9B7EC6"/>
        </view>
        <view class="setting-row" bindtap="pullFromCloud" wx:if="{{cloudEnabled}}">
          <view class="setting-info">
            <text class="setting-label">从云端恢复</text>
            <text class="setting-desc">将云端数据覆盖到本地</text>
          </view>
          <text class="picker-btn">点击同步 ▼</text>
        </view>
        <view class="setting-row" wx:if="{{cloudOpenid}}">
          <view class="setting-info">
            <text class="setting-label">当前身份</text>
            <text class="setting-desc">{{cloudOpenid}}</text>
          </view>
        </view>
        <view class="setting-row" wx:if="{{!cloudEnabled}}">
          <view class="setting-info">
            <text class="setting-label">云端状态</text>
            <text class="setting-desc">关闭后仅保留本机数据，重新开启后可继续同步</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 提醒设置 -->

    <view class="settings-section">
      <view class="section-title">🔔 提醒设置</view>
      <view class="settings-card">
        <view class="setting-row">
          <view class="setting-info">
            <text class="setting-label">开启提醒</text>
            <text class="setting-desc">姨妈前收到微信通知</text>
          </view>
          <switch checked="{{localSettings.remindEnabled}}" bindchange="toggleRemind" color="#9B7EC6"/>
        </view>
        <view class="setting-row">
          <view class="setting-info">
            <text class="setting-label">提前提醒</text>
            <text class="setting-desc">姨妈开始前{{localSettings.remindBefore}}天通知</text>
          </view>
          <picker mode="selector" range="{{remindDaysOptions}}" value="{{remindDaysIndex}}" bindchange="onRemindDaysChange">
            <view class="picker-btn">{{localSettings.remindBefore}} 天 ▼</view>
          </picker>
        </view>
        <view class="setting-row">
          <view class="setting-info">
            <text class="setting-label">姨妈当天提醒</text>
            <text class="setting-desc">姨妈首日发送通知</text>
          </view>
          <switch checked="{{localSettings.remindOnDay}}" bindchange="toggleRemindOnDay" color="#9B7EC6"/>
        </view>
      </view>
    </view>

    <!-- 间隔设置 -->
    <view class="settings-section">
      <view class="section-title">📐 间隔设置</view>
      <view class="settings-card">
        <view class="setting-row">
          <view class="setting-info">
            <text class="setting-label">平均间隔</text>
            <text class="setting-desc">记录3个周期后支持自动调整</text>
          </view>
          <picker mode="selector" range="{{cycleOptions}}" value="{{cycleIndex}}" bindchange="onCycleChange">
            <view class="picker-btn">{{localSettings.cycleLength}} 天 ▼</view>
          </picker>
        </view>
        <view class="setting-row">
          <view class="setting-info">
            <text class="setting-label">暴躁期</text>
            <text class="setting-desc">通常固定14天，请勿随意修改</text>
          </view>
          <text class="setting-value locked">{{localSettings.lutealPhase}} 天</text>
        </view>
      </view>
    </view>

    <!-- 隐私保护 -->
    <view class="settings-section">
      <view class="section-title">🔐 隐私保护</view>
      <view class="settings-card">
        <view class="setting-row">
          <view class="setting-info">
            <text class="setting-label">开启密码锁</text>
            <text class="setting-desc">进入姨妈追踪需输入密码</text>
          </view>
          <switch checked="{{localSettings.pinEnabled}}" bindchange="togglePin" color="#9B7EC6"/>
        </view>
        <view class="setting-row" wx:if="{{localSettings.pinEnabled}}">
          <view class="setting-info">
            <text class="setting-label">修改密码</text>
          </view>
          <view class="picker-btn" bindtap="changePin">点击修改 ▼</view>
        </view>
        <view class="privacy-note">
          <text>🔒 姨妈记录默认保存在本机；开启云端同步后，会加密同步到你的 CloudBase 环境，仅用于多端恢复与提醒。</text>
        </view>
      </view>
    </view>

    <!-- 使用模式 -->
    <view class="settings-section">
      <view class="section-title">🎯 使用模式</view>
      <view class="settings-card">
        <view class="pill-group mode-pill-group">
          <view
            wx:for="{{modes}}" wx:key="key"
            class="pill-btn {{localSettings.mode === item.key ? 'active' : ''}}"
            bindtap="changeMode"
            data-val="{{item.key}}"
          >{{item.label}}</view>
        </view>
        <view class="mode-desc-row" wx:if="{{localSettings.mode === 'caution'}}">
          <text class="mode-desc-text">将稍微提前提示重点阶段，适合希望更早留意身体节奏的用户。</text>
        </view>
      </view>
    </view>

    <!-- 数据管理 -->
    <view class="settings-section">
      <view class="section-title">💾 数据管理</view>
      <view class="settings-card">
        <view class="setting-row" bindtap="exportData">
          <view class="setting-info">
            <text class="setting-label">导出数据</text>
            <text class="setting-desc">将记录导出为 JSON 文件</text>
          </view>
          <text class="picker-btn">导出 ▼</text>
        </view>
        <view class="setting-row danger" bindtap="clearData">
          <view class="setting-info">
            <text class="setting-label">清除所有数据</text>
            <text class="setting-desc">不可恢复，请谨慎操作</text>
          </view>
        </view>
      </view>
    </view>

  </view>
</view>

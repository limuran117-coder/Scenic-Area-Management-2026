<!-- pages/reminder/reminder.wxml - 提醒设置页面 -->

<view class="container">

  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="height: {{totalTopHeight}}px; padding-top: {{statusBarHeight}}px; box-sizing: border-box;">
    <view class="nav-content" style="height: {{navBarHeight}}px;">
      <view class="back-btn" bindtap="goBack">
        <image class="back-arrow-icon" src="/static/icons/system/back.svg" mode="aspectFit"></image>
      </view>
      <text class="nav-title">提醒设置</text>
      <view class="nav-space"></view>
    </view>
  </view>

  <view style="height: {{totalTopHeight + 8}}px; width: 100%; flex-shrink: 0;"></view>

  <!-- 1. 微信订阅消息授权状态卡片 -->
  <view class="section">
    <view class="card">
      <view class="card-row">
        <view class="card-row-left">
          <image class="card-icon" src="/static/icons/system/bell.svg" mode="aspectFit"></image>
          <view class="card-row-text">
            <text class="card-row-title">微信订阅消息</text>
            <text class="card-row-desc">{{isSubscribed ? '已授权，可接收提醒' : '未授权，无法接收微信提醒'}}</text>
          </view>
        </view>
        <view class="card-row-right">
          <view class="status-badge {{isSubscribed ? 'status-ok' : 'status-no'}}">
            <text>{{isSubscribed ? '已授权' : '未授权'}}</text>
          </view>
        </view>
      </view>
      <view class="card-action" wx:if="{{!isSubscribed}}" bindtap="openSubscribe">
        <text class="action-text">去开启微信提醒</text>
        <text class="action-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 2. 如何开启提醒 -->
  <view class="section">
    <view class="section-label">如何开启</view>
    <view class="card">
      <view class="help-row">
        <text class="help-num">1</text>
        <text class="help-text">在纪念日详情页，点击右上角提醒按钮</text>
      </view>
      <view class="setting-divider"></view>
      <view class="help-row">
        <text class="help-num">2</text>
        <text class="help-text">选择当天、提前1天、3天或7天提醒</text>
      </view>
      <view class="setting-divider"></view>
      <view class="help-row">
        <text class="help-num">3</text>
        <text class="help-text">确保上方微信订阅已开启，即可接收推送</text>
      </view>
      <view class="setting-divider"></view>
      <view class="help-row">
        <text class="help-num">4</text>
        <text class="help-text">提醒将在每天早上 9:00 发送</text>
      </view>
    </view>
  </view>

  <!-- 3. 已开启提醒的倒计时列表 -->
  <view class="section" wx:if="{{reminderItems.length > 0}}">
    <view class="section-label">已开启提醒 · {{reminderItems.length}}项</view>
    <view class="card">
      <block wx:for="{{reminderItems}}" wx:key="id">
        <view class="reminder-item" bindtap="goToDetail" data-id="{{item.id}}">
          <view class="reminder-item-left">
            <text class="reminder-icon">{{item.icon}}</text>
            <view class="reminder-item-info">
              <text class="reminder-item-title">{{item.title}}</text>
              <text class="reminder-item-date">{{item.targetDateText}}</text>
            </view>
          </view>
          <view class="reminder-item-right">
            <text class="reminder-days-tag">{{item.remindDaysText}}</text>
            <text class="reminder-arrow">›</text>
          </view>
        </view>
        <view class="setting-divider" wx:if="{{index < reminderItems.length - 1}}"></view>
      </block>
    </view>
  </view>

  <!-- 空状态：暂未开启任何提醒 -->
  <view class="section" wx:elif="{{reminderItems.length === 0}}">
    <view class="section-label">已开启提醒</view>
    <view class="card empty-card">
      <text class="empty-text">暂未开启任何提醒</text>
      <text class="empty-hint">在纪念日详情页开启提醒后，将在此显示</text>
    </view>
  </view>

  <!-- 4. 姨妈提醒卡片 -->
  <view class="section">
    <view class="section-label">姨妈提醒</view>
    <view class="card">
      <view class="setting-row">
        <view class="setting-row-left">
          <text class="setting-label">姨妈提醒</text>
          <text class="setting-hint">开启后姨妈前N天发微信提醒</text>
        </view>
        <switch class="setting-switch" checked="{{periodRemindEnabled}}" bindchange="onPeriodRemindChange" color="#F5BFD4"/>
      </view>
      <view class="setting-divider" wx:if="{{periodRemindEnabled}}"></view>
      <view class="setting-row" wx:if="{{periodRemindEnabled}}">
        <view class="setting-row-left">
          <text class="setting-label">提前天数</text>
        </view>
        <picker class="picker-wrap" mode="selector" range="{{periodAdvanceOptions}}" range-key="label" value="{{periodAdvanceIndex}}" bindchange="onPeriodAdvanceChange">
          <view class="picker-value">{{periodAdvanceOptions[periodAdvanceIndex].label}}</view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-spacer"></view>

</view>

/* pages/reminder/reminder.wxss - 提醒设置页面样式 */

.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background:
    radial-gradient(circle at 8% 12%, rgba(239, 225, 169, 0.42) 0, rgba(239, 225, 169, 0) 38%),
    radial-gradient(circle at 92% 6%, rgba(205, 231, 255, 0.58) 0, rgba(205, 231, 255, 0) 36%),
    radial-gradient(circle at 18% 78%, rgba(251, 207, 222, 0.4) 0, rgba(251, 207, 222, 0) 40%),
    radial-gradient(circle at 82% 86%, rgba(174, 231, 222, 0.3) 0, rgba(174, 231, 222, 0) 42%),
    radial-gradient(circle at 50% 42%, rgba(255, 255, 255, 0.52) 0, rgba(255, 255, 255, 0) 44%),
    linear-gradient(180deg, #FAFCFF, #F7F9FE);
}

/* ===== 自定义导航栏 ===== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(247, 249, 254, 0.58);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.66);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow-icon {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 38rpx;
  font-weight: 600;
  color: #243247;
  letter-spacing: 6rpx;
}

.nav-space {
  width: 64rpx;
  height: 64rpx;
}

/* ===== 通用卡片 ===== */
.section {
  padding: 0 40rpx;
  margin-bottom: 30rpx;
}

.section-label {
  font-size: 24rpx;
  color: #9C8C82;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
  letter-spacing: 1rpx;
  font-weight: 500;
}

.card {
  border-radius: 40rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(22px);
  -webkit-backdrop-filter: blur(22px);
  border: 1rpx solid rgba(228, 235, 246, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(83, 99, 129, 0.06);
}

/* ===== 1. 订阅状态卡片 ===== */
.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 36rpx;
}

.card-row-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.card-icon {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  opacity: 0.7;
}

.card-row-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.card-row-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #243247;
}

.card-row-desc {
  font-size: 24rpx;
  color: #9C8C82;
  line-height: 1.4;
}

.card-row-right {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-ok {
  background: rgba(120, 160, 144, 0.1);
  color: #78A090;
}

.status-no {
  background: rgba(192, 80, 112, 0.1);
  color: #c05070;
}

.card-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 36rpx;
  border-top: 1rpx solid rgba(228, 235, 246, 0.92);
  background: rgba(184, 120, 136, 0.06);
}

.card-action:active {
  background: rgba(184, 120, 136, 0.12);
}

.action-text {
  font-size: 26rpx;
  color: #B87888;
  font-weight: 500;
}

.action-arrow {
  font-size: 36rpx;
  color: #B87888;
}

/* ===== 2. 设置行 ===== */
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 36rpx;
  min-height: 56rpx;
}

.setting-row-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.setting-label {
  font-size: 30rpx;
  color: #243247;
  font-weight: 400;
}

.setting-hint {
  font-size: 22rpx;
  color: #9C8C82;
  line-height: 1.4;
}

.setting-divider {
  height: 1rpx;
  background: rgba(228, 235, 246, 0.92);
  margin: 0 36rpx;
}

.picker-wrap {
  flex-shrink: 0;
}

.picker-value {
  font-size: 26rpx;
  color: #B87888;
  padding: 8rpx 16rpx;
  background: rgba(184, 120, 136, 0.08);
  border-radius: 16rpx;
}

.setting-switch {
  flex-shrink: 0;
  transform: scale(0.85);
}

/* ===== 2. 如何开启说明 ===== */
.help-row {
  display: flex;
  align-items: center;
  padding: 24rpx 36rpx;
  gap: 20rpx;
}

.help-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(184, 120, 136, 0.1);
  color: #B87888;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.help-text {
  font-size: 26rpx;
  color: #243247;
  line-height: 1.5;
}

/* ===== 3. 提醒列表 ===== */
.reminder-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 36rpx;
}

.reminder-item:active {
  background: rgba(184, 120, 136, 0.06);
}

.reminder-item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.reminder-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  width: 52rpx;
  text-align: center;
}

.reminder-item-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.reminder-item-title {
  font-size: 28rpx;
  color: #243247;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reminder-item-date {
  font-size: 22rpx;
  color: #9C8C82;
}

.reminder-item-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.reminder-days-tag {
  font-size: 22rpx;
  color: #B87888;
  padding: 4rpx 14rpx;
  background: rgba(184, 120, 136, 0.08);
  border-radius: 12rpx;
}

.reminder-arrow {
  font-size: 36rpx;
  color: #9C8C82;
  font-weight: 300;
}

/* ===== 空状态 ===== */
.empty-card {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9C8C82;
}

.empty-hint {
  font-size: 22rpx;
  color: #9C8C82;
  text-align: center;
  line-height: 1.5;
}

/* ===== 底部留白 ===== */
.bottom-spacer {
  height: 80rpx;
}

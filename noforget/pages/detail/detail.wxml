<view class="detail-page cat-{{item.categoryId}}">

  <view class="detail-nav" style="height: {{totalTopHeight}}px; padding-top: {{statusBarHeight}}px; box-sizing: border-box;">
    <view class="detail-nav-row" style="height: {{navBarHeight}}px;">
      <view class="detail-back-btn" bindtap="goBack">
        <image class="detail-back-arrow-icon" src="/static/icons/system/back.svg" mode="aspectFit"></image>
      </view>
      <view class="detail-nav-center">
        <text class="detail-nav-title-text">NO FORGET</text>
      </view>
      <view style="width:52rpx;"></view>
    </view>
  </view>

  <view class="detail-content {{item && !item.coverImage ? 'detail-content-plain' : ''}} {{item && item.coverImage ? 'detail-content-cover' : ''}}" style="padding-top: {{totalTopHeight}}px;">
    <block wx:if="{{item && !item.coverImage}}">
      <view class="glass-hero-card">
        <view class="hero-category detail-pill-macaron">
          <text class="hero-category-text">{{item.categoryLabelEn}}</text>
        </view>

        <view class="hero-center-block">
          <view class="hero-countdown-stack">
            <text class="hero-countdown-num">{{item.countdownPreciseDays}}</text>
            <text class="hero-countdown-unit">{{item.headlineUnit}}</text>
          </view>

          <view class="hero-hms-row" wx:if="{{item.countdownHms}}">
            <text class="hero-hms">{{item.countdownHms}}</text>
          </view>
        </view>

        <view class="hero-meta">
          <text class="hero-title">{{item.title}}</text>
          <text class="hero-date">{{item.dateStr}}</text>
          <text class="hero-copy">{{item.statusText}}</text>
        </view>
      </view>
    </block>

    <block wx:if="{{item && item.coverImage}}">
      <view class="cover-area" bindtap="previewCover">
        <image class="cover-img" src="{{item.coverImage}}" mode="aspectFill" />
        <view class="cover-mask"></view>
      </view>
      <view class="info-card">
        <view class="category-tag"><text>{{item.categoryLabelEn}}</text></view>
        <view class="countdown-area">
          <view class="days-wrapper">
            <text class="days-num">{{item.countdownPreciseDays}}</text>
            <text class="days-unit">Days</text>
          </view>
          <text class="sub-timer" wx:if="{{item.countdownHms}}">{{item.countdownHms}}</text>
        </view>
        <view class="card-header">
          <view class="event-title">{{item.title}}</view>
          <view class="event-date">{{item.dateStr}}</view>
        </view>
      </view>
    </block>

    <view class="footer-note">
      <view class="detail-sub-line">
        <text class="detail-sub-text">{{item.detailSub}}</text><text class="detail-sub-emoji"> 🎉</text>
      </view>
      <text class="detail-sub-en">The moment stays soft and bright.</text>
    </view>
  </view>

  <view class="detail-bottom-bar">
    <view class="side-action-btn {{remindEnabled ? 'active' : ''}}" bindtap="toggleRemind">
      <view class="side-icon-wrap icon-shell-left"><image class="detail-action-icon" src="/static/icons/system/bell.svg" mode="aspectFit"></image></view>
    </view>

    <view class="share-btn-huge" bindtap="shareCard">
      <view class="share-btn-glow"></view>
      <text class="share-btn-text">生成纪念画报</text>
    </view>

    <view class="side-action-btn" bindtap="goToEdit">
      <view class="side-icon-wrap icon-shell-right"><image class="detail-action-icon" src="/static/icons/system/edit.svg" mode="aspectFit"></image></view>
    </view>
  </view>

  <view class="crop-modal" wx:if="{{showShareCropper}}" catchtouchmove="preventTouch">
    <canvas canvas-id="cropCanvas" class="crop-canvas" style="width: {{canvasWidth || 375}}px; height: {{canvasHeight || 240}}px;"></canvas>
    <view class="crop-header" style="padding-top: {{statusBarHeight + 52}}px;">
      <text class="crop-title">调整画报影像</text>
    </view>
    <view class="crop-body">
      <view class="crop-wrapper" bindtouchstart="onCropTouchStart" bindtouchmove="onCropTouchMove">
        <image class="crop-image" src="{{cropImagePath}}" mode="widthFix"></image>
        <view class="crop-frame" style="top: {{cropFrameTop}}px; height: {{cropFrameHeight}}px;"></view>
        <view class="crop-mask-top" style="height: {{cropFrameTop}}px;"></view>
        <view class="crop-mask-bottom" style="top: {{cropFrameTop + cropFrameHeight}}px;"></view>
        <view class="crop-hint"><text style="color: #FFF; font-size: 13px;">↑↓ 拖动选择显示区域</text></view>
      </view>
    </view>
    <view class="crop-actions">
      <view class="crop-action crop-action-secondary" bindtap="cancelShareCrop">取消</view>
      <view class="crop-action crop-action-primary" bindtap="confirmShareCrop">完成</view>
    </view>
  </view>

  <view class="poster-preview-modal" wx:if="{{posterPreviewPath}}" catchtouchmove="preventTouch">
    <view class="poster-preview-panel">
      <image class="poster-preview-image" src="{{posterPreviewPath}}" mode="aspectFit" bindtap="previewGeneratedPoster"></image>
      <view class="poster-preview-actions">
        <view class="poster-preview-action muted" bindtap="closePosterPreview">关闭</view>
        <view class="poster-preview-action primary" bindtap="previewGeneratedPoster">查看大图</view>
      </view>
      <text class="poster-preview-tip">长按大图即可保存到相册</text>
    </view>
  </view>

  <canvas canvas-id="shareCanvas" class="poster-canvas" style="width: {{posterCanvasWidth || 1080}}px; height: {{posterCanvasHeight || 1440}}px;"></canvas>

</view>

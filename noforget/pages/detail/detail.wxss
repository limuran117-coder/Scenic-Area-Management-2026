page {
  background: #f7f9fe;
}

.detail-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 12% 8%, rgba(251, 207, 222, 0.52) 0, rgba(251, 207, 222, 0) 36%),
    radial-gradient(circle at 88% 24%, rgba(205, 231, 255, 0.58) 0, rgba(205, 231, 255, 0) 38%),
    radial-gradient(circle at 20% 82%, rgba(239, 225, 169, 0.28) 0, rgba(239, 225, 169, 0) 40%),
    radial-gradient(circle at 78% 82%, rgba(174, 231, 222, 0.3) 0, rgba(174, 231, 222, 0) 38%),
    radial-gradient(circle at 54% 46%, rgba(255, 255, 255, 0.5) 0, rgba(255, 255, 255, 0) 44%),
    #f7f9fe;
  background-size: 140% 140%;
  animation: detail-mist-drift 18s ease-in-out infinite alternate;
}

@keyframes detail-mist-drift {
  0% { background-position: 0% 8%; }
  100% { background-position: 100% 92%; }
}

.detail-page,
.detail-page view {
  box-sizing: border-box;
}

.cat-birthday { --detail-cat-color: #F7C1B7; --detail-cat-ink: #AE756A; --detail-cat-soft: rgba(247,193,183,0.34); }
.cat-love { --detail-cat-color: #F3A9B6; --detail-cat-ink: #AE6D7A; --detail-cat-soft: rgba(243,169,182,0.32); }
.cat-wedding { --detail-cat-color: #EBC7A4; --detail-cat-ink: #9F7A55; --detail-cat-soft: rgba(235,199,164,0.34); }
.cat-death { --detail-cat-color: #C9CAD6; --detail-cat-ink: #747789; --detail-cat-soft: rgba(201,202,214,0.34); }
.cat-pet_birthday { --detail-cat-color: #B8B6E8; --detail-cat-ink: #7472AA; --detail-cat-soft: rgba(184,182,232,0.34); }
.cat-repayment { --detail-cat-color: #C8DCC8; --detail-cat-ink: #6F9074; --detail-cat-soft: rgba(200,220,200,0.34); }
.cat-period { --detail-cat-color: #F5BFD4; --detail-cat-ink: #AC7389; --detail-cat-soft: rgba(245,191,212,0.34); }
.cat-onboarding { --detail-cat-color: #BBD8EE; --detail-cat-ink: #6F91AA; --detail-cat-soft: rgba(187,216,238,0.34); }
.cat-vehicle { --detail-cat-color: #C8D3DD; --detail-cat-ink: #6D7F8C; --detail-cat-soft: rgba(200,211,221,0.34); }
.cat-festival { --detail-cat-color: #E7D9A8; --detail-cat-ink: #9A8859; --detail-cat-soft: rgba(231,217,168,0.34); }

.detail-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1200;
  background: rgba(247,249,254,0.72);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

.detail-nav-row {
  display: flex;
  align-items: center;
  position: relative;
  padding: 0 40rpx;
}

.detail-back-btn {
  width: 88rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-shrink: 0;
}

.detail-back-arrow-icon {
  width: 40rpx;
  height: 40rpx;
}

.detail-nav-center {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.detail-nav-title-text {
  font-size: 38rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
  color: #243247;
  white-space: nowrap;
}

.detail-content {
  padding: 12rpx 28rpx calc(160rpx + env(safe-area-inset-bottom, 0));
}

.detail-content-cover {
  padding-top: calc(var(--detail-cover-offset, 0px));
  padding-bottom: calc(96rpx + env(safe-area-inset-bottom, 0));
}

.detail-content-plain {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 0;
}

.glass-hero-card,
.info-card,
.side-icon-wrap {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(22px);
  -webkit-backdrop-filter: blur(22px);
  border: 1rpx solid rgba(228, 235, 246, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(83, 99, 129, 0.06);
}

.glass-hero-card {
  width: 100%;
  height: 700rpx;
  min-height: 0;
  margin: 0 auto;
  border-radius: 40rpx;
  padding: 42rpx 34rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.52);
  border: 1rpx solid rgba(255,255,255,0.28);
  box-shadow: 0 18rpx 44rpx rgba(120, 85, 94, 0.12);
}

.hero-category {
  align-self: center;
  padding: 14rpx 34rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.42);
  border: 1rpx solid rgba(255,255,255,0.26);
  color: #6C7C95;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-pill-macaron {
  box-shadow: none;
}

.hero-category-icon {
  font-size: 0;
  line-height: 1;
}

.hero-category-text {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  line-height: 1;
}

.hero-center-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  flex: 1;
  transform: translateY(-2rpx);
}

.hero-countdown-stack {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.hero-countdown-num {
  font-size: 164rpx;
  line-height: 0.9;
  font-weight: 700;
  color: var(--detail-cat-ink, #1d2026);
  letter-spacing: -4rpx;
}

.hero-countdown-unit {
  margin-top: 12rpx;
  font-size: 50rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
  color: var(--detail-cat-ink, #5c555d);
  opacity: 0.86;
}

.hero-hms-row {
  margin-top: 10rpx;
}

.hero-hms {
  font-size: 42rpx;
  letter-spacing: 6rpx;
  color: var(--detail-cat-color, #b08e95);
  opacity: 0.92;
}

.hero-meta {
  padding-bottom: 4rpx;
  width: 100%;
  text-align: center;
}

.hero-title {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  color: var(--detail-cat-ink, #1d2026);
}

.hero-date {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--detail-cat-color, #97a2bb);
}

.hero-copy {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--detail-cat-ink, #b58e95);
  opacity: 0.78;
  letter-spacing: 0.8rpx;
}

.cover-area {
  width: auto;
  height: 582rpx;
  border-radius: 44rpx;
  overflow: hidden;
  position: relative;
  margin: 52rpx 6rpx 0;
  z-index: 2;
  box-shadow: 0 18rpx 40rpx rgba(83, 99, 129, 0.085);
}

.cover-img {
  width: 100%;
  height: 100%;
  display: block;
}

.cover-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(24, 24, 24, 0.012) 0%, rgba(24, 24, 24, 0) 60%, rgba(247,249,254,0.08) 88%, rgba(247,249,254,0.28) 100%),
    radial-gradient(ellipse at 18% 104%, var(--detail-cat-soft, rgba(251, 239, 245, 0.14)) 0, rgba(255,255,255,0.04) 34%, transparent 64%),
    radial-gradient(ellipse at 84% 104%, rgba(214, 233, 255, 0.14) 0, rgba(255,255,255,0.04) 34%, transparent 64%);
  pointer-events: none;
  z-index: 1;
}

.cover-area::after {
  content: "";
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  bottom: 0;
  height: 18rpx;
  background:
    linear-gradient(180deg, rgba(247,249,254,0) 0%, rgba(247,249,254,0.06) 100%);
  filter: blur(2rpx);
  pointer-events: none;
  z-index: 2;
}

.info-card {
  margin: 14rpx 6rpx 0;
  min-height: 392rpx;
  border-radius: 42rpx;
  padding: 28rpx 34rpx 24rpx;
  position: relative;
  z-index: 4;
  overflow: visible;
  display: flex;
  flex-direction: column;
  align-items: center;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.68) 0%, rgba(255,255,255,0.86) 36%, rgba(255,255,255,0.78) 100%),
    radial-gradient(ellipse at 22% 0%, var(--detail-cat-soft, rgba(251,239,245,0.28)) 0, rgba(255,255,255,0.08) 36%, transparent 66%),
    radial-gradient(ellipse at 80% 2%, rgba(214,233,255,0.24) 0, rgba(255,255,255,0.08) 36%, transparent 66%);
  backdrop-filter: blur(28px) saturate(152%);
  -webkit-backdrop-filter: blur(28px) saturate(152%);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 18rpx 44rpx rgba(83, 99, 129, 0.075);
}

.info-card::before {
  content: "";
  position: absolute;
  left: 6rpx;
  right: 6rpx;
  top: -8rpx;
  height: 12rpx;
  border-radius: 40rpx 40rpx 26rpx 26rpx;
  background: rgba(255,255,255,0.18);
  filter: blur(2rpx);
  pointer-events: none;
  z-index: 0;
}

.category-tag,
.countdown-area,
.card-header {
  position: relative;
  z-index: 1;
}

.category-tag {
  padding: 14rpx 34rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(255,255,255,0.42);
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--detail-cat-ink, #6C7C95);
}

.countdown-area {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.days-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.days-num {
  font-size: 116rpx;
  line-height: 0.92;
  font-weight: 700;
  color: var(--detail-cat-ink, #243247);
}

.days-unit {
  margin-top: 10rpx;
  font-size: 50rpx;
  color: var(--detail-cat-ink, #7A8AA2);
  opacity: 0.86;
}

.sub-timer {
  margin-top: 18rpx;
  font-size: 46rpx;
  letter-spacing: 6rpx;
  color: var(--detail-cat-color, #95A8C0);
}

.card-header {
  margin-top: auto;
  text-align: center;
}

.event-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--detail-cat-ink, #243247);
}

.event-date {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--detail-cat-color, #8898B0);
}

.footer-note {
  margin-top: 22rpx;
  text-align: center;
  padding: 0 42rpx;
}

.detail-sub-line {
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-sub-text {
  font-size: 28rpx;
  color: var(--detail-cat-ink, #6f6973);
  line-height: 1.6;
}

.detail-sub-emoji {
  font-size: 28rpx;
}

.detail-sub-en {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: var(--detail-cat-color, #9AA6BA);
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.detail-bottom-bar {
  position: fixed;
  left: 26rpx;
  right: 26rpx;
  bottom: calc(16rpx + env(safe-area-inset-bottom, 0));
  z-index: 1300;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.side-action-btn {
  width: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.side-icon-wrap {
  width: 76rpx;
  height: 76rpx;
  border-radius: 38rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.78), rgba(255,255,255,0.54)),
    radial-gradient(circle at 22% 18%, rgba(244,191,209,0.22), transparent 42%),
    radial-gradient(circle at 84% 80%, rgba(217,232,255,0.24), transparent 44%);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.56);
  box-shadow: 0 12rpx 24rpx rgba(104, 128, 160, 0.1);
}

.icon-shell-right {
  background:
    linear-gradient(135deg, rgba(255,255,255,0.78), rgba(255,255,255,0.54)),
    radial-gradient(circle at 22% 18%, rgba(244,191,209,0.22), transparent 42%),
    radial-gradient(circle at 84% 80%, rgba(217,232,255,0.24), transparent 44%);
}

.side-action-btn.active .side-icon-wrap {
  box-shadow: 0 10rpx 24rpx rgba(136, 171, 211, 0.18);
}

.share-btn-huge {
  flex: 1;
  height: 78rpx;
  border-radius: 39rpx;
  background:
    linear-gradient(135deg, rgba(244,191,209,0.54) 0%, rgba(217,232,255,0.54) 100%),
    rgba(255,255,255,0.38);
  backdrop-filter: blur(18px) saturate(160%);
  -webkit-backdrop-filter: blur(18px) saturate(160%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 28rpx rgba(159, 183, 220, 0.16);
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
}

.share-btn-glow {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 18% 22%, rgba(255,255,255,0.5), transparent 34%),
    radial-gradient(circle at 84% 78%, rgba(255,255,255,0.28), transparent 28%),
    linear-gradient(90deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02));
}

.share-btn-text {
  position: relative;
  z-index: 1;
  color: #4D5A70;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  line-height: 1;
  white-space: pre-line;
  letter-spacing: 1rpx;
}

.detail-action-icon {
  width: 54rpx;
  height: 54rpx;
  display: block;
}

.crop-modal {
  position: fixed;
  inset: 0;
  background: rgba(18, 18, 18, 0.76);
  z-index: 1500;
  display: flex;
  flex-direction: column;
}

.crop-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 20px;
  min-height: 44px;
  background: rgba(24, 24, 24, 0.44);
  backdrop-filter: blur(18px);
}

.crop-cancel,
.crop-confirm,
.crop-title {
  color: #fff;
  font-size: 32rpx;
}

.crop-confirm {
  font-weight: 600;
}

.crop-actions {
  display: flex;
  gap: 24rpx;
  padding: 22rpx 40rpx calc(28rpx + env(safe-area-inset-bottom));
  background: rgba(18, 18, 18, 0.48);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}

.crop-action {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.crop-action-secondary {
  color: #fff;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.crop-action-primary {
  color: #fff;
  background: linear-gradient(135deg, rgba(245, 191, 212, 0.94), rgba(181, 215, 235, 0.94));
  box-shadow: 0 14rpx 36rpx rgba(245, 191, 212, 0.22);
}

.crop-body {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.crop-wrapper {
  width: 100%;
  position: relative;
}

.crop-image {
  width: 100%;
  display: block;
}

.crop-frame {
  position: absolute;
  left: 0;
  right: 0;
  border-top: 1.5px solid rgba(255,255,255,0.9);
  border-bottom: 1.5px solid rgba(255,255,255,0.9);
  box-sizing: border-box;
  z-index: 5;
}

.crop-mask-top,
.crop-mask-bottom {
  position: absolute;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.6);
  z-index: 4;
}

.crop-mask-top {
  top: 0;
}

.crop-mask-bottom {
  bottom: 0;
}

.crop-hint {
  position: absolute;
  bottom: 160rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  z-index: 6;
}

.crop-canvas {
  position: fixed;
  top: 0;
  left: 0;
  opacity: 0.001;
  pointer-events: none;
  z-index: 1;
}

.poster-canvas {
  width: 1080px;
  height: 1440px;
  position: fixed;
  left: 0;
  top: 0;
  opacity: 0.001;
  pointer-events: none;
  z-index: 1;
}

.poster-preview-modal {
  position: fixed;
  inset: 0;
  z-index: 1600;
  background: rgba(38, 42, 54, 0.42);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 44rpx calc(56rpx + env(safe-area-inset-bottom));
}

.poster-preview-panel {
  width: 100%;
  max-height: 88vh;
  border-radius: 42rpx;
  padding: 28rpx;
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(145deg, rgba(255,255,255,0.74), rgba(255,255,255,0.5)),
    radial-gradient(ellipse at 8% 2%, rgba(245,191,212,0.58) 0, rgba(245,191,212,0.16) 42%, transparent 74%),
    radial-gradient(ellipse at 94% 4%, rgba(187,216,238,0.58) 0, rgba(187,216,238,0.16) 42%, transparent 72%),
    radial-gradient(ellipse at 8% 100%, rgba(174,231,222,0.4) 0, rgba(174,231,222,0.12) 44%, transparent 74%),
    radial-gradient(ellipse at 92% 98%, rgba(239,225,169,0.38) 0, rgba(239,225,169,0.12) 44%, transparent 72%);
  box-shadow: 0 28rpx 80rpx rgba(63, 76, 104, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.poster-preview-panel::before {
  content: "";
  position: absolute;
  inset: -18%;
  background:
    radial-gradient(ellipse at 12% 12%, rgba(245,191,212,0.4) 0, transparent 44%),
    radial-gradient(ellipse at 88% 12%, rgba(187,216,238,0.42) 0, transparent 42%),
    radial-gradient(ellipse at 22% 88%, rgba(174,231,222,0.26) 0, transparent 42%),
    radial-gradient(ellipse at 82% 86%, rgba(239,225,169,0.24) 0, transparent 40%);
  filter: blur(22rpx);
  pointer-events: none;
}

.poster-preview-image {
  width: 100%;
  height: 920rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.18);
  position: relative;
  z-index: 1;
}

.poster-preview-actions {
  width: 100%;
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
  position: relative;
  z-index: 1;
}

.poster-preview-action {
  flex: 1;
  height: 82rpx;
  border-radius: 41rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 650;
}

.poster-preview-action.muted {
  color: #7B8799;
  background: rgba(255, 255, 255, 0.58);
}

.poster-preview-action.primary {
  color: #fff;
  background: linear-gradient(135deg, rgba(245, 191, 212, 0.94), rgba(181, 215, 235, 0.94));
  box-shadow: 0 14rpx 34rpx rgba(168, 191, 225, 0.22);
}

.poster-preview-tip {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: rgba(86, 98, 116, 0.62);
  letter-spacing: 1rpx;
  position: relative;
  z-index: 1;
}

/* pages/privacy/privacy.wxss */

page {
  background:
    radial-gradient(circle at 10% 8%, rgba(205, 231, 255, 0.5) 0, rgba(205, 231, 255, 0) 38%),
    radial-gradient(circle at 90% 12%, rgba(251, 207, 222, 0.38) 0, rgba(251, 207, 222, 0) 36%),
    radial-gradient(circle at 18% 82%, rgba(239, 225, 169, 0.24) 0, rgba(239, 225, 169, 0) 40%),
    radial-gradient(circle at 82% 78%, rgba(174, 231, 222, 0.28) 0, rgba(174, 231, 222, 0) 38%),
    linear-gradient(180deg, #FAFCFF, #F7F9FE);
  background-size: 140% 140%;
  animation: privacy-mist-drift 19s ease-in-out infinite alternate;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  color: #243247;
}

@keyframes privacy-mist-drift {
  0% { background-position: 0% 10%; }
  100% { background-position: 100% 90%; }
}

/* ─── 导航栏 ─────────────────────────────────── */
.nav-bar {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  background: rgba(247,249,254,0.72);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  z-index: 1000;
}
.nav-left {
  width: 80rpx;
  display: flex;
  align-items: center;
}
.nav-arrow {
  position: relative;
  width: 40rpx;
  height: 40rpx;
}
.nav-arrow::before {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 9rpx;
  width: 16rpx;
  height: 16rpx;
  border-left: 2.6rpx solid #243247;
  border-bottom: 2.6rpx solid #243247;
  border-radius: 2rpx;
  transform: rotate(45deg);
}
.nav-title { font-size: 32rpx; font-weight: 600; color: #243247; flex: 1; text-align: center; }
.nav-right { width: 80rpx; }

/* ─── 内容区域 ─────────────────────────────────── */
.spacer { width: 100%; }

.content {
  height: calc(100vh - 88rpx);
  padding: 32rpx;
  box-sizing: border-box;
}

/* ─── 章节样式 ─────────────────────────────────── */
.section {
  margin-bottom: 48rpx;
}
.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #4A3728;
  margin-bottom: 20rpx;
  line-height: 1.4;
}
.section-text {
  display: block;
  font-size: 28rpx;
  color: #5D5448;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
}
.list-bullet {
  font-size: 28rpx;
  color: #B87888;
  margin-right: 12rpx;
  flex-shrink: 0;
  line-height: 1.8;
}
.list-text {
  font-size: 28rpx;
  color: #5D5448;
  line-height: 1.8;
  flex: 1;
}

/* 联系卡片 */
.contact-card {
  background: #FFF5F6;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-top: 16rpx;
  border: 1.5rpx solid rgba(184,120,136,0.15);
}
.contact-text {
  display: block;
  font-size: 30rpx;
  color: #4A3728;
  font-weight: 500;
  margin-bottom: 8rpx;
}
.contact-note {
  display: block;
  font-size: 24rpx;
  color: #9C8C82;
}

.last-update {
  font-size: 24rpx;
  color: #9C8C82;
  margin-top: 24rpx;
  display: block;
}

.bottom-spacer {
  height: 60rpx;
}

/* pages/mine/mine.wxss - 极致审美版 v19 */

.container {
  min-height: 100vh;
  padding-bottom: 100rpx;
  background:
    radial-gradient(circle at 8% 12%, rgba(239, 225, 169, 0.42) 0, rgba(239, 225, 169, 0) 38%),
    radial-gradient(circle at 92% 6%, rgba(205, 231, 255, 0.58) 0, rgba(205, 231, 255, 0) 36%),
    radial-gradient(circle at 18% 78%, rgba(251, 207, 222, 0.4) 0, rgba(251, 207, 222, 0) 40%),
    radial-gradient(circle at 82% 86%, rgba(174, 231, 222, 0.3) 0, rgba(174, 231, 222, 0) 42%),
    radial-gradient(circle at 50% 42%, rgba(255, 255, 255, 0.52) 0, rgba(255, 255, 255, 0) 44%),
    linear-gradient(180deg, #FAFCFF, #F7F9FE);
  background-size: 146% 146%;
  animation: mine-mist-drift 17s ease-in-out infinite alternate;
}

@keyframes mine-mist-drift {
  0% { background-position: 8% 4%; }
  100% { background-position: 92% 96%; }
}

.card-shadow {
  box-shadow: 0 14rpx 40rpx rgba(26,26,26,0.05);
}

/* ===== 1. 顶部导航 ===== */
.nav-bar {
  padding: 0 40rpx 20rpx;
}

.nav-content {
  display: flex;
  align-items: center;
  height: 44px;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow-icon {
  width: 38rpx;
  height: 38rpx;
}

/* ===== 2. 用户头部：居中大画幅设计，彻底解决椭圆 ===== */
.user-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 60rpx;
}

/* 🌟 核心修复：锁死 button 宽高，永远正圆 */
.avatar-wrapper {
  width: 180rpx !important;
  height: 180rpx !important;
  padding: 0 !important;
  margin: 0 !important;
  border-radius: 50%;
  background: #FFFFFF;
  position: relative;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 16rpx 40rpx rgba(26,26,26,0.05);
}

.avatar-wrapper::after {
  border: none;
}

.avatar-real {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #F6F5F4;
  display: flex;
  justify-content: center;
  align-items: center;
}

.avatar-line-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  border: 3rpx solid #B7B2A8;
  position: relative;
  box-sizing: border-box;
}

.avatar-line-icon::before,
.avatar-line-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  background: #B7B2A8;
}

.avatar-line-icon::before {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  top: 11rpx;
}

.avatar-line-icon::after {
  width: 34rpx;
  height: 10rpx;
  border-radius: 999rpx 999rpx 8rpx 8rpx;
  bottom: 10rpx;
}

.icon-wrap {
  width: 48rpx;
  height: 48rpx;
  position: relative;
  flex-shrink: 0;
}


/* 右下角精致小相机图标 */
.edit-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 56rpx;
  height: 56rpx;
  background: #FFF;
  border-radius: 50%;
  font-size: 28rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.user-text-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 30rpx;
}

.nickname {
  font-size: 44rpx;
  font-weight: bold;
  color: #1A1A1A;
  letter-spacing: 2rpx;
}

.user-desc {
  font-size: 26rpx;
  color: #787671;
  margin-top: 10rpx;
  letter-spacing: 1rpx;
}

/* ===== 3. 数据仪表盘 ===== */
.dashboard-section {
  padding: 0 40rpx 40rpx;
}

.dashboard-card {
  border-radius: 40rpx;
  padding: 40rpx 20rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.65) !important;
  backdrop-filter: blur(24px) saturate(160%);
  -webkit-backdrop-filter: blur(24px) saturate(160%);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.dash-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  gap: 8rpx;
}

.dash-num {
  font-size: 56rpx;
  font-weight: 300;
  font-family: 'Helvetica Neue', sans-serif;
}

.dash-label {
  font-size: 24rpx;
  color: #787671;
}

.dash-divider {
  width: 1px;
  height: 60rpx;
  background: #E5E3DF;
}

/* ===== 4. 功能面板 ===== */
.menu-section {
  padding: 0 40rpx;
}

.menu-group {
  border-radius: 28rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.65) !important;
  backdrop-filter: blur(24px) saturate(160%);
  -webkit-backdrop-filter: blur(24px) saturate(160%);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx;
  gap: 24rpx;
  border-bottom: 1rpx solid rgba(229,227,223,0.9);
  transition: background 0.2s;
}

.menu-item.no-border {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(86,69,212,0.05);
}

.icon-wrap {
  width: 48rpx;
  height: 48rpx;
  background: transparent !important;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  flex-shrink: 0;
}

.icon-wrap.danger {
  background: transparent !important;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #2F2A25;
  font-weight: 400;
  letter-spacing: 1rpx;
}

.menu-arrow {
  font-size: 40rpx;
  color: #B4AB9F;
  font-weight: 300;
}

.logout-text {
  color: #FF3B30;
}

/* ===== 5. 底部品牌印记 ===== */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 12rpx;
}

.footer-version {
  font-size: 20rpx;
  color: #A4A097;
  letter-spacing: 2rpx;
}

.footer-slogan {
  font-size: 24rpx;
  color: #787671;
  letter-spacing: 1rpx;
}

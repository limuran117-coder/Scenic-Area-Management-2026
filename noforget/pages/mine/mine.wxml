<!-- pages/mine/mine.wxml - 极简高级版个人中心 v19 -->

<view class="container theme-{{currentTheme}}" style="font-family: {{theme.fontFamily}};">

  <!-- 1. 顶部导航 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="back-btn" bindtap="goBack">
        <image class="back-arrow-icon" src="/static/icons/system/back.svg" mode="aspectFit"></image>
      </view>
    </view>
  </view>

  <!-- 2. 用户头部信息区（居中大头像设计，彻底修复椭圆） -->
  <view class="user-header">
    <button class="avatar-wrapper card-shadow" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar-real" src="{{userAvatar}}" mode="aspectFill" wx:if="{{userAvatar}}"></image>
      <view class="avatar-placeholder" wx:else><view class="avatar-line-icon"></view></view>
    </button>
    <view class="user-text-area">
      <text class="nickname">{{userAvatar ? (nickName || '我') : '点击设置头像'}}</text>
      <text class="user-desc">记录每一个重要时刻</text>
    </view>
  </view>

  <!-- 3. 数据仪表盘 -->
  <view class="dashboard-section">
    <view class="dashboard-card card-shadow">
      <view class="dash-item" bindtap="showStatInfo" data-stat="total">
        <text class="dash-num" style="color: {{theme.textPrimary}};">{{formattedStats.total}}</text>
        <text class="dash-label">总记录</text>
      </view>
      <view class="dash-divider"></view>
      <view class="dash-item" bindtap="showStatInfo" data-stat="upcoming">
        <text class="dash-num" style="color: {{theme.textPrimary}};">{{formattedStats.upcoming}}</text>
        <text class="dash-label">即将到来</text>
      </view>
      <view class="dash-divider"></view>
      <view class="dash-item" bindtap="showStatInfo" data-stat="past">
        <text class="dash-num" style="color: {{theme.textPrimary}};">{{formattedStats.past}}</text>
        <text class="dash-label">已过纪念</text>
      </view>
    </view>
  </view>

  <!-- 4. 功能面板 -->
  <view class="menu-section">
    <view class="menu-group card-shadow">
      <view class="menu-item" bindtap="switchTheme">
        <image class="icon-wrap" src="/static/icons/system/theme.svg" mode="aspectFit"></image>
        <text class="menu-text">主题设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goReminderSettings">
        <image class="icon-wrap" src="/static/icons/system/bell.svg" mode="aspectFit"></image>
        <text class="menu-text">提醒设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item no-border" bindtap="exportData">
        <image class="icon-wrap" src="/static/icons/system/export.svg" mode="aspectFit"></image>
        <text class="menu-text">导出数据</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group card-shadow">
      <view class="menu-item" bindtap="goAbout">
        <image class="icon-wrap" src="/static/icons/system/info.svg" mode="aspectFit"></image>
        <text class="menu-text">关于 No Forget</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item no-border" bindtap="contactUs">
        <image class="icon-wrap" src="/static/icons/system/chat.svg" mode="aspectFit"></image>
        <text class="menu-text">意见反馈</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group card-shadow" wx:if="{{userAvatar}}">
      <view class="menu-item no-border logout-item" bindtap="clearAvatar">
        <image class="icon-wrap danger" src="/static/icons/system/trash.svg" mode="aspectFit"></image>
        <text class="menu-text logout-text">清除头像</text>
      </view>
    </view>
  </view>

  <!-- 5. 底部品牌印记 -->
  <view class="footer">
    <text class="footer-version">No Forget v1.0.0</text>
    <text class="footer-slogan">NO FORGET · 重要时刻档案</text>
  </view>
  <tab-bar active="mine"></tab-bar>
</view>

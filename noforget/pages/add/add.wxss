.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at 8% 18%, rgba(205, 231, 255, 0.58) 0, rgba(205, 231, 255, 0) 36%),
    radial-gradient(circle at 92% 8%, rgba(251, 207, 222, 0.58) 0, rgba(251, 207, 222, 0) 38%),
    radial-gradient(circle at 78% 76%, rgba(174, 231, 222, 0.34) 0, rgba(174, 231, 222, 0) 42%),
    radial-gradient(circle at 18% 88%, rgba(239, 225, 169, 0.28) 0, rgba(239, 225, 169, 0) 38%),
    radial-gradient(circle at 50% 42%, rgba(255, 255, 255, 0.48) 0, rgba(255, 255, 255, 0) 44%),
    #f7f9fe;
  background-size: 142% 142%;
  animation: mist-drift 17s ease-in-out infinite alternate;
  color: #243247;
}

@keyframes mist-drift {
  0% { background-position: 8% 0%; }
  100% { background-position: 92% 100%; }
}

.nav-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(247, 249, 254, 0.58);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.66);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  height: 42px;
}

.nav-side {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 38rpx;
  font-weight: 600;
  color: #243247;
  letter-spacing: 6rpx;
}

.nav-icon-image {
  width: 40rpx;
  height: 40rpx;
}

.add-scroll {
  height: 100%;
}

.create-content {
  padding: 34rpx 32rpx calc(192rpx + env(safe-area-inset-bottom, 0));
}

.postcard-wrapper {
  padding-top: 12rpx;
}

.postcard,
.btn-cover,
.mode-card,
.date-picker-btn,
.cat-pill,
.remind-pill {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(22px);
  -webkit-backdrop-filter: blur(22px);
  border: 1rpx solid rgba(228, 235, 246, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(83, 99, 129, 0.06);
}

.postcard {
  width: 100%;
  min-height: 560rpx;
  border-radius: 40rpx;
  overflow: hidden;
  position: relative;
}

.postcard.period-postcard {
  background:
    radial-gradient(circle at 16% 14%, rgba(142, 223, 212, 0.44) 0, rgba(142, 223, 212, 0) 42%),
    radial-gradient(circle at 86% 16%, rgba(248, 195, 203, 0.42) 0, rgba(248, 195, 203, 0) 40%),
    radial-gradient(circle at 16% 88%, rgba(231, 217, 168, 0.34) 0, rgba(231, 217, 168, 0) 40%),
    radial-gradient(circle at 86% 88%, rgba(184, 182, 232, 0.34) 0, rgba(184, 182, 232, 0) 40%),
    linear-gradient(135deg, rgba(239, 255, 250, 0.74), rgba(255, 245, 249, 0.6));
  border: 0;
}

.postcard-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.postcard-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(28, 26, 22, 0.08) 0%, rgba(28, 26, 22, 0.24) 100%);
}

.postcard-inner {
  position: relative;
  z-index: 1;
  min-height: 560rpx;
  padding: 42rpx 34rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.period-postcard .postcard-inner {
  padding: 0;
}

.pc-category-row {
  margin-top: 8rpx;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.58);
  border: 1rpx solid rgba(229,235,245,0.92);
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.pc-category-en {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: #6F91AA;
  line-height: 1;
}

.pc-category-cn {
  font-size: 24rpx;
  font-weight: 650;
  color: #B07780;
  line-height: 1;
}

.pc-center {
  margin: 22rpx 0 28rpx;
}

.pc-num {
  font-size: 132rpx;
  line-height: 0.94;
  font-weight: 300;
  color: #94AFCF;
  letter-spacing: -8rpx;
}

.pc-input-wrap {
  width: calc(100% - 66rpx);
  margin-top: auto;
  border: 2rpx solid rgba(229, 235, 245, 0.92);
  background: rgba(255, 255, 255, 0.7);
}

.pc-title-input {
  width: 100%;
  height: 96rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #5B6D89;
  text-align: center;
}

.pc-placeholder {
  color: #9BA8BC;
  text-align: center;
}

.pc-title-static {
  margin-top: 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #5B6D89;
}

.period-special-preview {
  width: 100%;
  min-height: 560rpx;
  height: 560rpx;
  padding: 68rpx 42rpx 62rpx;
  border-radius: 40rpx;
  background:
    radial-gradient(circle at 18% 16%, rgba(142,223,212,0.42), transparent 42%),
    radial-gradient(circle at 84% 18%, rgba(248,195,203,0.38), transparent 40%),
    radial-gradient(circle at 16% 88%, rgba(231,217,168,0.3), transparent 42%),
    radial-gradient(circle at 88% 88%, rgba(184,182,232,0.3), transparent 42%),
    linear-gradient(135deg, rgba(255,255,255,0.22), rgba(255,255,255,0.04));
  border: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.period-preview-mark {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 34% 30%, rgba(255,255,255,0.95), transparent 22%),
    linear-gradient(135deg, rgba(142,223,212,0.92), rgba(248,195,203,0.76));
  box-shadow: 0 14rpx 28rpx rgba(142, 188, 202, 0.18);
  margin-bottom: 28rpx;
}

.period-preview-kicker {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 5rpx;
  color: #5A9B95;
  line-height: 1;
}

.period-preview-title {
  margin-top: 20rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #25384B;
  letter-spacing: 1.2rpx;
  line-height: 1.25;
}

.period-preview-desc {
  margin-top: 22rpx;
  max-width: 500rpx;
  font-size: 25rpx;
  color: #6C7C95;
  line-height: 1.85;
  letter-spacing: 0.8rpx;
}

.period-preview-tags {
  margin-top: 32rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.period-preview-tags text {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.58);
  border: 1rpx solid rgba(255,255,255,0.72);
  font-size: 21rpx;
  color: #5A9B95;
}

.btn-cover {
  width: calc(100% - 170rpx);
  margin: 28rpx auto 0;
  height: 82rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  color: #6D89B0;
  font-size: 22rpx;
  font-weight: 600;
}

.btn-cover-icon {
  position: relative;
  width: 32rpx;
  height: 32rpx;
}

.btn-cover-icon::before {
  content: "";
  position: absolute;
  inset: 4rpx;
  border: 2.2rpx solid #86A3C8;
  border-radius: 5rpx;
}

.btn-cover-icon::after {
  content: "";
  position: absolute;
  left: 8rpx;
  bottom: 8rpx;
  width: 14rpx;
  height: 10rpx;
  border-left: 2.2rpx solid #86A3C8;
  border-bottom: 2.2rpx solid #86A3C8;
  transform: skew(-28deg);
  box-shadow: 10rpx -10rpx 0 -7rpx #86A3C8;
}

.btn-cover-remove {
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #C08AA8;
}

.settings-section {
  margin-top: 56rpx;
}

.mode-wrap {
  display: flex;
  gap: 20rpx;
  margin-bottom: 38rpx;
}

.mode-card {
  flex: 1;
  min-height: 156rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.mode-card.active {
  background:
    linear-gradient(135deg, rgba(234, 244, 255, 0.9), rgba(255, 247, 251, 0.66)),
    rgba(255,255,255,0.66);
  border-color: rgba(210, 226, 246, 0.92);
}

.mode-icon-image {
  width: 48rpx;
  height: 48rpx;
}

.mode-name {
  font-size: 28rpx;
  font-weight: 650;
  color: #5E708C;
  letter-spacing: 0.8rpx;
}

.setting-group {
  margin-bottom: 30rpx;
}

.setting-title {
  margin: 0 0 14rpx 8rpx;
  font-size: 22rpx;
  color: #8190A5;
}

.date-picker-btn {
  min-height: 114rpx;
  border-radius: 30rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-picker-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.date-picker-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: rgba(234, 244, 255, 0.9);
  position: relative;
}

.date-picker-icon::before {
  content: "";
  position: absolute;
  inset: 12rpx 10rpx 10rpx;
  border: 2rpx solid #7D96BA;
  border-radius: 4rpx;
}

.date-picker-icon::after {
  content: "";
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  top: 11rpx;
  height: 8rpx;
  border-top: 2rpx solid #7D96BA;
  box-shadow: -6rpx 0 0 -1rpx #7D96BA, 6rpx 0 0 -1rpx #7D96BA;
}

.date-val {
  font-size: 26rpx;
  color: #243247;
}

.date-arrow-icon {
  width: 16rpx;
  height: 16rpx;
  border-top: 2.6rpx solid #8A99AD;
  border-right: 2.6rpx solid #8A99AD;
  transform: rotate(45deg);
}

.category-wrap {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  column-gap: 12rpx;
  row-gap: 14rpx;
}

.cat-pill {
  width: 100%;
  height: 60rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.82), rgba(255,255,255,0.56)),
    var(--cat-pill-soft, rgba(234,244,255,0.18));
  border-color: rgba(230, 236, 246, 0.82);
}

.cat-pill.active {
  background:
    linear-gradient(135deg, var(--cat-pill-soft, rgba(251,239,245,0.5)), rgba(255,255,255,0.62)),
    rgba(255,255,255,0.7);
  border-color: var(--cat-pill-color, #D8B7C8);
  box-shadow: 0 16rpx 34rpx rgba(96, 115, 145, 0.08);
}

.cat-name {
  font-size: 23rpx;
  font-weight: 650;
  color: var(--cat-pill-ink, #4D5F79);
  line-height: 1;
  white-space: nowrap;
}

.remind-group {
  margin-top: 18rpx;
}

.remind-flex {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.remind-pill {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #78879B;
}

.remind-pill.active {
  background: rgba(234, 244, 255, 0.96);
  color: #60759A;
}

.bottom-fab {
  position: fixed;
  left: 50%;
  width: 82%;
  bottom: calc(22rpx + env(safe-area-inset-bottom, 0));
  z-index: 120;
  display: flex;
  gap: 16rpx;
  transform: translateX(-50%);
}

.fab-btn-save {
  flex: 1;
  height: 92rpx;
  border-radius: 999rpx;
  background:
    linear-gradient(135deg, rgba(151, 184, 222, 0.72) 0%, rgba(238, 187, 207, 0.72) 100%),
    radial-gradient(circle at 14% 18%, rgba(255,255,255,0.62), transparent 36%),
    rgba(255,255,255,0.42);
  backdrop-filter: blur(22px) saturate(160%);
  -webkit-backdrop-filter: blur(22px) saturate(160%);
  border: 1rpx solid rgba(255,255,255,0.68);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 18rpx 38rpx rgba(151, 171, 208, 0.2);
}

.fab-btn-save.half {
  flex: 0 0 68%;
}

.fab-zh {
  color: #fff;
  font-size: 27rpx;
  font-weight: 700;
  letter-spacing: 0.8rpx;
}

.fab-arrow {
  width: 18rpx;
  height: 18rpx;
  border-top: 3rpx solid #fff;
  border-right: 3rpx solid #fff;
  transform: rotate(45deg);
}

.fab-btn-delete {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.56);
  backdrop-filter: blur(18px);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #C08AA8;
  font-size: 22rpx;
}

.crop-modal {
  position: fixed;
  inset: 0;
  background: rgba(18, 18, 18, 0.76);
  z-index: 1500;
  display: flex;
  flex-direction: column;
}

.crop-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20px;
  min-height: 44px;
  background: rgba(24, 24, 24, 0.44);
  backdrop-filter: blur(18px);
}

.crop-cancel,
.crop-confirm,
.crop-title {
  color: #fff;
  font-size: 32rpx;
}

.crop-confirm {
  font-weight: 600;
}

.crop-body {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.crop-wrapper {
  width: 100%;
  position: relative;
}

.crop-image {
  width: 100%;
  display: block;
}

.crop-frame {
  position: absolute;
  left: 0;
  right: 0;
  border-top: 1.5px solid rgba(255,255,255,0.9);
  border-bottom: 1.5px solid rgba(255,255,255,0.9);
  box-sizing: border-box;
  z-index: 5;
}

.crop-mask-top,
.crop-mask-bottom {
  position: absolute;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.6);
  z-index: 4;
}

.crop-mask-top {
  top: 0;
}

.crop-mask-bottom {
  bottom: 0;
}

.crop-hint {
  position: absolute;
  bottom: 160rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  z-index: 6;
}

.crop-canvas {
  position: fixed;
  top: -9999px;
  left: -9999px;
  opacity: 0;
}

<view class="container theme-{{currentTheme}}">

  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-side nav-side-left" bindtap="goBack">
        <image class="nav-icon-image" src="/static/icons/system/back.svg" mode="aspectFit"></image>
      </view>
      <text class="nav-title">NO FORGET</text>
      <view class="nav-side nav-side-right">
        <image class="nav-icon-image" src="/static/icons/system/bell.svg" mode="aspectFit"></image>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="add-scroll">
    <view class="create-content">
      <view class="postcard-wrapper">
        <view class="postcard {{coverImage ? 'has-cover' : ''}} {{categoryId === 'period' ? 'period-postcard' : ''}}">
          <image wx:if="{{coverImage}}" class="postcard-bg" src="{{coverImage}}" mode="aspectFill"></image>
          <view wx:if="{{coverImage}}" class="postcard-overlay"></view>

          <view class="postcard-inner">
            <block wx:if="{{categoryId === 'period'}}">
              <view class="period-special-preview">
                <view class="period-preview-mark"></view>
                <text class="period-preview-kicker">LUNA CARE</text>
                <text class="period-preview-title">姨妈日专属追踪</text>
                <text class="period-preview-desc">记录开始日期后，系统会根据周期自动推算下次姨妈、重点阶段与日历提示。</text>
                <view class="period-preview-tags">
                  <text>周期预测</text>
                  <text>日历标注</text>
                  <text>温柔提醒</text>
                </view>
              </view>
            </block>

            <block wx:else>
              <view class="pc-category-row">
                <text class="pc-category-en">{{previewCategoryEn}}</text>
                <text class="pc-category-cn">{{previewCategoryName}}</text>
              </view>
              <view class="pc-center" wx:if="{{targetDate}}">
                <text class="pc-num">{{previewCountdownDays}}</text>
              </view>
              <view class="pc-input-wrap">
                <input
                  class="pc-title-input"
                  placeholder="给这个时刻起个名字"
                  placeholder-class="pc-placeholder"
                  value="{{title}}"
                  bindinput="onTitleInput"
                  maxlength="20"
                />
              </view>
            </block>
          </view>
        </view>

        <view class="btn-cover" wx:if="{{categoryId !== 'period'}}" bindtap="pickCoverImage">
          <view class="btn-cover-icon"></view>
          <text>{{coverImage ? '更换专属背景' : '添加专属背景'}}</text>
        </view>
        <view class="btn-cover-remove" wx:if="{{categoryId !== 'period' && coverImage}}" bindtap="removeCoverImage">移除背景</view>
      </view>

      <view class="settings-section">
        <view class="mode-wrap" wx:if="{{categoryId !== 'period'}}">
          <view class="mode-card {{mode === 'future' ? 'active' : ''}}" bindtap="switchToFuture">
            <image class="mode-icon-image" src="/static/icons/system/future.svg" mode="aspectFit"></image>
            <text class="mode-name">倒数未来</text>
          </view>

          <view class="mode-card {{mode === 'past' ? 'active' : ''}}" bindtap="switchToPast">
            <image class="mode-icon-image" src="/static/icons/system/past.svg" mode="aspectFit"></image>
            <text class="mode-name">累计时光</text>
          </view>
        </view>

        <view class="setting-group">
          <text class="setting-title">日期</text>
          <picker mode="date" value="{{targetDate}}" bindchange="onDateChange" start="1900-01-01" end="2099-12-31">
            <view class="date-picker-btn">
              <view class="date-picker-left">
                <view class="date-picker-icon"></view>
                <text class="date-val">{{targetDate ? targetDate : '设置日期'}}</text>
              </view>
              <view class="date-arrow-icon"></view>
            </view>
          </picker>
        </view>

        <view class="setting-group">
          <text class="setting-title">分类</text>
          <view class="category-wrap">
            <block wx:for="{{categories}}" wx:key="id">
              <view class="cat-pill {{selectedCategory === item.id ? 'active' : ''}}" style="--cat-pill-color: {{item.color}}; --cat-pill-soft: {{item.colorLight}}; --cat-pill-ink: {{item.colorText}};" bindtap="selectCategory" data-id="{{item.id}}">
                <text class="cat-name">{{item.name}}</text>
              </view>
            </block>
          </view>
        </view>

        <view class="setting-group remind-group">
          <text class="setting-title">提醒</text>
          <view class="remind-flex">
            <view class="remind-pill {{remindDays === 0 ? 'active' : ''}}" bindtap="setRemind" data-days="0">当天</view>
            <view class="remind-pill {{remindDays === 1 ? 'active' : ''}}" bindtap="setRemind" data-days="1">提前1天</view>
            <view class="remind-pill {{remindDays === 7 ? 'active' : ''}}" bindtap="setRemind" data-days="7">提前7天</view>
            <view class="remind-pill {{remindDays === -1 ? 'active' : ''}}" bindtap="setRemind" data-days="-1">不提醒</view>
          </view>
        </view>
      </view>

      <view style="height: 260rpx;"></view>
    </view>
  </scroll-view>

  <view class="bottom-fab">
    <view class="fab-btn-save {{isEdit ? 'half' : ''}}" bindtap="saveItem">
      <text class="fab-zh">{{isEdit ? '保存这个时刻' : '记录这一天'}}</text>
      <view class="fab-arrow"></view>
    </view>
    <view class="fab-btn-delete" wx:if="{{isEdit}}" bindtap="deleteItem">删除</view>
  </view>

  <view class="crop-modal" wx:if="{{showCropper}}" catchtouchmove="preventTouch">
    <canvas canvas-id="cropCanvas" class="crop-canvas" style="width: {{canvasWidth || 375}}px; height: {{canvasHeight || 240}}px;"></canvas>
    <view class="crop-header" style="padding-top: {{statusBarHeight + 52}}px;">
      <text class="crop-cancel" bindtap="cancelCrop">取消</text>
      <text class="crop-title">调整影像区域</text>
      <text class="crop-confirm" bindtap="confirmCrop">完成</text>
    </view>
    <view class="crop-body">
      <view class="crop-wrapper" bindtouchstart="onCropTouchStart" bindtouchmove="onCropTouchMove" bindtouchend="onCropTouchEnd">
        <image class="crop-image" src="{{cropImagePath}}" mode="widthFix"></image>
        <view class="crop-frame" style="top: {{cropFrameTop}}px; height: {{cropFrameHeight}}px;"></view>
        <view class="crop-mask-top" style="height: {{cropFrameTop}}px;"></view>
        <view class="crop-mask-bottom" style="top: {{cropFrameTop + cropFrameHeight}}px;"></view>
        <view class="crop-hint">
          <text style="color: #FFF; font-size: 13px;">↑↓ 拖动选择显示区域</text>
        </view>
      </view>
    </view>
  </view>

</view>

<!-- pages/index/index.wxml - 首页 v17 -->
<view class="page-container">

  <view class="page-fixed-bg"></view>

  <!-- 自定义导航栏 -->
  <view class="custom-header" style="height: {{totalTopHeight}}px; padding-top: {{statusBarHeight}}px; box-sizing: border-box;">
    <view class="nav-content" style="height: {{navHeight}}px;">
      <view class="nav-left"></view>
      <view class="nav-title">NO FORGET</view>
    </view>
  </view>

  <!-- 内容区 -->
  <scroll-view class="scroll-area {{listData.length === 0 ? 'is-empty' : ''}}" scroll-y="{{listData.length > 0}}" scroll-with-animation scroll-into-view="{{scrollIntoView}}" lower-threshold="200" bindscrolltolower="loadMore">
    <view id="top-anchor" style="height: 1rpx; width: 1rpx;"></view>
    <view style="height: {{totalTopHeight}}px; width: 100%; flex-shrink: 0;"></view>

    <!-- 每日黄历入口 -->
    <view class="huangli-strip" wx:if="{{dailyHuangli}}" bindtap="goToAlmanac">
      <view class="strip-date">
        <text class="strip-kicker">今日黄历</text>
        <text class="strip-day">{{dailyHuangli.solarDate}}</text>
        <text class="strip-lunar">{{dailyHuangli.week}} · {{dailyHuangli.lunarFull}}</text>
      </view>
      <view class="strip-actions">
        <view class="strip-pill good"><text class="strip-pill-label good">宜</text><text class="strip-pill-value">{{dailyHuangli.yi}}</text></view>
        <view class="strip-pill avoid"><text class="strip-pill-label avoid">忌</text><text class="strip-pill-value">{{dailyHuangli.ji}}</text></view>
      </view>
      <text class="strip-arrow">›</text>
    </view>

    <!-- 🌟 极简高级版空状态 -->
    <block wx:if="{{listData.length === 0}}">
      <view class="empty-state">
        <view class="empty-text-group">
          <text class="empty-title">让重要日期，有迹可循</text>
          <text class="empty-subtitle">Keep every meaningful day in view.</text>
          <view class="empty-divider"></view>
          <text class="empty-desc">把纪念日、生日和值得留下的瞬间\n整理成一份轻盈的时间档案</text>
        </view>
      </view>
    </block>

    <!-- 每日一言Banner -->
    <view class="daily-banner cat-{{dailyBanner ? dailyBanner.catId : 'default'}} {{showDailyBanner ? 'banner-show' : 'banner-hide'}}" wx:if="{{dailyBanner}}" bindtap="dismissBanner">
      <view class="banner-emoji">{{dailyBanner.emoji}}</view>
      <text class="banner-text">{{dailyBanner.text}}</text>
      <view class="banner-close">✕</view>
      <view class="banner-label">每日一言</view>
    </view>

    <!-- 卡片列表 -->
    <block wx:if="{{listData.length > 0}}">
      <view class="card-list">
        <block wx:for="{{listData}}" wx:key="id">

          <view wx:if="{{item.isPeriod && item.hasPeriodData}}" class="event-card theme-period card-shadow" bindtap="goToDetail" data-id="{{item.id}}">
            <!-- 灵魂大数字水印 -->
            <text class="huge-num">D{{item.periodDay || '1'}}</text>
            <view class="card-content">

              <view class="card-left">
                <view class="card-header">
                  <view class="title-wrap">
                    <text class="icon">{{item.currentPhaseIcon || item.icon}}</text>
                    <text class="title-txt">{{item.currentPhaseName || item.title}}</text>
                  </view>
                </view>
                <view class="card-subtitle">{{item.currentPhaseSlogan || item.cardSubtitle}}</view>
                <view class="card-footer">
                  <view class="footer-info-item">
                    <text class="info-label">当前阶段</text>
                    <text class="info-value">{{item.statusMain}}</text>
                  </view>
                  <view class="footer-info-item">
                    <text class="info-label">下次预计</text>
                    <text class="info-value">{{item.nextDate || '—'}}</text>
                  </view>
                </view>
              </view>

            </view>
          </view>

          <view wx:else class="event-card theme-{{item.category}} card-shadow" bindtap="goToDetail" data-id="{{item.id}}">
            <view class="card-content">
              <view class="card-left">
                <view class="card-title">
                  <text class="icon">{{item.icon}}</text>
                  <text class="title-txt">{{item.title}}</text>
                </view>
                <view class="card-subtitle">{{item.cardSubtitle}}</view>
                <view class="card-grid">
                  <view class="grid-item">
                    <text class="grid-label">起始</text>
                    <text class="grid-value">{{item.dateStr}}</text>
                  </view>
                  <view class="grid-divider"></view>
                  <view class="grid-item">
                    <text class="grid-label">状态</text>
                    <text class="grid-value">{{item.preciseIsPast ? '已成往事' : '满怀期待'}}</text>
                  </view>
                </view>
              </view>
              <text class="huge-num {{item.isHugeNumLong ? 'huge-num-long' : ''}}">{{item.countdownPreciseDays}}</text>
            </view>
          </view>

        </block>
      </view>
      <block wx:if="{{hasMore}}">
        <view class="load-more">{{loadingMore ? '加载中...' : '上滑加载更多'}}</view>
      </block>
    </block>

    <view style="height: 160rpx; flex-shrink: 0;"></view>
  </scroll-view>

  <!-- 底部导航 -->
  <tab-bar active="index"></tab-bar>

</view>

/* ============================================================
   index.wxss — 首页 v18
   ============================================================ */

/* 修改后的外层容器：干干净净，只管布局 */
.page-container {
  height: 100vh;
  position: relative;
  display: flex;
  flex-direction: column;
}

/* 🌟 固定的底层壁纸，永远铺满全屏不留死角 */
.page-fixed-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: -1;
  pointer-events: none;
  background:
    radial-gradient(circle at 4% 6%, rgba(251, 207, 222, 0.62) 0, rgba(251, 207, 222, 0) 38%),
    radial-gradient(circle at 96% 10%, rgba(205, 231, 255, 0.68) 0, rgba(205, 231, 255, 0) 36%),
    radial-gradient(circle at 14% 74%, rgba(174, 231, 222, 0.42) 0, rgba(174, 231, 222, 0) 40%),
    radial-gradient(circle at 82% 68%, rgba(239, 225, 169, 0.36) 0, rgba(239, 225, 169, 0) 38%),
    radial-gradient(circle at 50% 38%, rgba(255, 255, 255, 0.54) 0, rgba(255, 255, 255, 0) 46%),
    linear-gradient(180deg, #FAFCFF, #F7F9FE);
  background-size: 145% 145%;
  animation: mist-drift 16s ease-in-out infinite alternate;
}

@keyframes mist-drift {
  0%   { background-position: 0% 0%; }
  100% { background-position: 100% 100%; }
}

/* 一、自定义导航栏 */
.custom-header {
  position: fixed;
  top: 0; left: 0;
  width: 100%;
  background: rgba(247,249,254,0.72);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  z-index: 100;
  box-sizing: border-box;
}

.nav-content {
  display: flex;
  align-items: center;
  position: relative;
  padding: 0 40rpx;
}

.nav-left {
  width: 88rpx;
  height: 100%;
  flex-shrink: 0;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 38rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
  color: #243247;
}

/* 二、滚动区域 */
.scroll-area {
  flex: 1;
  box-sizing: border-box;
}

.scroll-area.is-empty {
  overflow: hidden;
}

/* 三、🌟 极简高级版空状态 (纯文字排版) */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
  height: calc(100vh - 580rpx);
  margin-top: -20rpx;
  box-sizing: border-box;
}

.empty-text-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-title {
  font-size: 44rpx;
  font-weight: 200;
  color: #243247;
  letter-spacing: 10rpx;
  line-height: 1.4;
  margin-left: 10rpx;
}

.empty-subtitle {
  font-size: 20rpx;
  color: #8F9BB0;
  letter-spacing: 6rpx;
  margin-top: 24rpx;
  font-family: Georgia, "Times New Roman", serif;
  text-transform: uppercase;
  margin-left: 6rpx;
}

.empty-divider {
  width: 80rpx;
  height: 2rpx;
  background: rgba(205,196,185,0.7);
  border-radius: 2rpx;
  margin: 70rpx 0;
}

.empty-desc {
  font-size: 24rpx;
  color: #6C7C95;
  line-height: 2.2;
  letter-spacing: 2rpx;
  text-align: center;
  font-weight: 200;
}

/* 四、每日一言Banner */
.daily-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 30rpx;
  margin: 22rpx 32rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.82), rgba(255,255,255,0.56)),
    radial-gradient(circle at 8% 0%, rgba(251,239,245,0.28), transparent 46%);
  backdrop-filter: blur(22px) saturate(180%);
  -webkit-backdrop-filter: blur(22px) saturate(180%);
  border: 1px solid rgba(225,232,243,0.78);
  box-shadow: 0 14rpx 34rpx rgba(83,99,129,0.05);
}

.banner-emoji { font-size: 34rpx; flex-shrink: 0; }
.banner-text { flex: 1; font-size: 24rpx; font-weight: 500; color: #243247; line-height: 1.5; letter-spacing: 0.4rpx; }
.banner-close { font-size: 22rpx; color: #c7c7c7; padding: 8rpx; flex-shrink: 0; }
.banner-label { font-size: 19rpx; color: #8F9BB0; letter-spacing: 2rpx; font-weight: 600; flex-shrink: 0; }

/* 五、🌟 杂志级排版卡片列表 */
.card-list {
  padding: 0 36rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.event-card {
  border-radius: 36rpx;
  padding: 36rpx 38rpx;
  min-height: 224rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.84), rgba(255,255,255,0.58)),
    radial-gradient(circle at 0% 0%, rgba(251,239,245,0.28), transparent 46%),
    radial-gradient(circle at 100% 10%, rgba(234,244,255,0.22), transparent 46%);
  border: 1rpx solid rgba(225,232,243,0.82);
  box-shadow: 0 18rpx 42rpx rgba(83,99,129,0.055);
  backdrop-filter: blur(16px) saturate(138%);
  -webkit-backdrop-filter: blur(16px) saturate(138%);
  animation: mist-rise 460ms var(--ease-out-quart) both;
}

/* 六、分类色：低饱和档案色，仅做局部强调 */
.event-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: var(--cat-color, #D8C2AD);
}

.theme-birthday { --cat-color: #F7C1B7; --cat-ink: #AE756A; --cat-num: rgba(247,193,183,0.46); }
.theme-love { --cat-color: #F3A9B6; --cat-ink: #AE6D7A; --cat-num: rgba(243,169,182,0.44); }
.theme-wedding { --cat-color: #EBC7A4; --cat-ink: #9F7A55; --cat-num: rgba(235,199,164,0.44); }
.theme-death { --cat-color: #C9CAD6; --cat-ink: #747789; --cat-num: rgba(201,202,214,0.44); }
.theme-pet_birthday { --cat-color: #B8B6E8; --cat-ink: #7472AA; --cat-num: rgba(184,182,232,0.44); }
.theme-repayment { --cat-color: #C8DCC8; --cat-ink: #6F9074; --cat-num: rgba(200,220,200,0.44); }
.theme-period { --cat-color: #F5BFD4; --cat-ink: #AC7389; --cat-num: rgba(245,191,212,0.46); }
.theme-onboarding { --cat-color: #BBD8EE; --cat-ink: #6F91AA; --cat-num: rgba(187,216,238,0.44); }
.theme-vehicle { --cat-color: #C8D3DD; --cat-ink: #6D7F8C; --cat-num: rgba(200,211,221,0.44); }
.theme-festival { --cat-color: #E7D9A8; --cat-ink: #9A8859; --cat-num: rgba(231,217,168,0.44); }

.event-card .title-txt,
.event-card .grid-value {
  color: #2F2A25;
}

.event-card .card-subtitle,
.event-card .grid-label {
  color: #7E766B;
}

.event-card .card-grid {
  border-color: rgba(205,196,185,0.56);
}

.event-card .huge-num {
  color: var(--cat-num);
}

.event-card .icon {
  color: var(--cat-ink);
}

/* --- 卡片内部结构 --- */
.card-content {
  display: flex;
  justify-content: space-between;
  height: 100%;
  position: relative;
}

.card-left {
  display: flex;
  flex-direction: column;
  z-index: 2;
  width: 64%;
}

.card-title {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-title .icon {
  font-size: 30rpx;
  margin-right: 16rpx;
}

.title-txt {
  font-family: var(--theme-font-family);
  font-size: 30rpx;
  font-weight: 600;
  color: inherit;
  letter-spacing: 1rpx;
}

.card-subtitle {
  font-family: var(--theme-font-family);
  font-size: 22rpx;
  color: inherit;
  opacity: 0.75;
  letter-spacing: 1rpx;
  margin-bottom: 28rpx;
}

.card-grid {
  display: flex;
  align-items: center;
  padding-top: 16rpx;
  width: max-content;
}

.grid-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.grid-label {
  font-family: var(--theme-font-family);
  font-size: 15rpx;
  opacity: 0.6;
  letter-spacing: 1rpx;
}

.grid-value {
  font-family: var(--theme-font-family);
  font-size: 18rpx;
  opacity: 0.9;
  letter-spacing: 1rpx;
  font-weight: 500;
}

.grid-divider {
  width: 1rpx;
  height: 36rpx;
  margin: 0 24rpx;
}

.huge-num {
  position: absolute;
  right: -36rpx;
  bottom: -40rpx;
  font-family: "Helvetica Neue", Helvetica, -apple-system, sans-serif;
  font-size: 300rpx;
  font-weight: 200;
  line-height: 0.75;
  letter-spacing: -8rpx;
  z-index: 1;
  pointer-events: none;
}

.huge-num-long {
  right: -58rpx;
  bottom: -58rpx;
  font-size: 244rpx;
  letter-spacing: -14rpx;
  line-height: 0.8;
}

/* ─── 姨妈日卡片结构重塑（与普通卡片对齐） ────────────────── */
.theme-period {
  --cat-color: #F5BFD4;
  --cat-ink: #AC7389;
  --cat-num: rgba(245,191,212,0.5);
}
.theme-period .huge-num {
  color: rgba(245,191,212,0.22);
  right: -24rpx;
  bottom: -40rpx;
  font-size: 320rpx;
  font-weight: 300;
  letter-spacing: -12rpx;
  font-family: -apple-system, sans-serif;
}

/* 头部一行：标题 + 胶囊按钮 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 2;
}
.title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.card-action-btn {
  font-size: 22rpx;
  color: #9C8C82;
  background: rgba(214, 189, 232, 0.15);
  padding: 10rpx 24rpx;
  border-radius: 100rpx;
  position: relative;
  z-index: 2;
}

/* 关怀文案 */
.theme-period .card-subtitle {
  margin-bottom: auto;
  padding-bottom: 40rpx;
  position: relative;
  z-index: 2;
}

/* 底部双栏数据 */
.card-footer {
  display: flex;
  gap: 64rpx;
  position: relative;
  z-index: 2;
}
.footer-info-item {
  display: flex;
  flex-direction: column;
}
.info-label {
  font-size: 20rpx;
  color: #BDB1A8;
  margin-bottom: 8rpx;
}
.info-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #2F2A25;
}

/* 七、底部导航 */
.bottom-nav-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  display: flex;
  justify-content: center;
  z-index: 120;
  padding: 0 0 env(safe-area-inset-bottom);
  box-sizing: border-box;
  background:
    linear-gradient(to top, rgba(247,249,254,0.98), rgba(247,249,254,0.84), rgba(247,249,254,0)),
    radial-gradient(circle at 22% 100%, rgba(251,239,245,0.34), transparent 46%),
    radial-gradient(circle at 82% 100%, rgba(234,244,255,0.28), transparent 44%);
}

.bottom-nav {
  width: 100%;
  max-width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 40rpx 18rpx;
  border-top: 1rpx solid rgba(225,232,243,0.86);
  background:
    linear-gradient(135deg, rgba(255,255,255,0.58), rgba(255,255,255,0.3)),
    radial-gradient(circle at 20% 0%, rgba(251,239,245,0.26), transparent 44%),
    radial-gradient(circle at 80% 0%, rgba(234,244,255,0.22), transparent 44%);
  backdrop-filter: blur(18px) saturate(138%);
  -webkit-backdrop-filter: blur(18px) saturate(138%);
}

.bottom-nav-item {
  flex: 1;
  min-height: 56rpx;
  color: #9AA8BE;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  margin-top: 2rpx;
}

.bottom-nav-item:active {
  opacity: 0.58;
}

.bottom-nav-item.is-active {
  color: #243247;
}

.bottom-nav-item.is-active .bottom-nav-icon::before,
.bottom-nav-item.is-active .bottom-nav-icon::after {
  opacity: 1;
}

.bottom-nav-item-create {
  color: #B687A3;
}

.bottom-nav-icon {
  width: 52rpx;
  height: 52rpx;
  position: relative;
}

.bottom-nav-icon::before,
.bottom-nav-icon::after {
  opacity: 0.85;
  transition: all 0.3s ease;
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  box-sizing: border-box;
}

.nav-icon-home::before {
  width: 32rpx;
  height: 32rpx;
  border-top: 3rpx solid currentColor;
  border-left: 3rpx solid currentColor;
  transform: translate(-50%, -42%) rotate(45deg);
  border-radius: 4rpx 0 0 0;
}
.nav-icon-home::after {
  width: 22rpx;
  height: 18rpx;
  border: 3rpx solid currentColor;
  border-top: none;
  top: 64%;
}

.nav-icon-create::before {
  width: 46rpx;
  height: 46rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  background: transparent;
}
.nav-icon-create::after {
  width: 22rpx;
  height: 22rpx;
  background:
    linear-gradient(currentColor, currentColor) center/22rpx 2rpx no-repeat,
    linear-gradient(currentColor, currentColor) center/2rpx 22rpx no-repeat;
}

.nav-icon-user::before {
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  top: 35%;
}
.nav-icon-user::after {
  width: 32rpx;
  height: 16rpx;
  border: 3rpx solid currentColor;
  border-bottom: none;
  border-radius: 16rpx 16rpx 0 0;
  top: 68%;
}


/* ===== 🌟 高定情绪日历卡（今日新增） ===== */
.premium-daily-card {
  margin: 10rpx 0 40rpx 0;
  background: rgba(255, 255, 255, 0.82);
  border-radius: 36rpx;
  border: 1px solid rgba(255, 255, 255, 0.9);
  padding: 30rpx 36rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

.daily-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 32rpx;
}

.daily-month {
  font-family: -apple-system, sans-serif;
  font-size: 20rpx;
  font-weight: 800;
  color: #F472B6;
  letter-spacing: 4rpx;
  margin-bottom: -6rpx;
}

.daily-day {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 56rpx;
  font-weight: 900;
  color: #111827;
  letter-spacing: -2rpx;
}

.daily-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(0, 0, 0, 0.06);
  margin-right: 32rpx;
}

.daily-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.daily-quote {
  font-family: "PingFang SC", "STHeiti", serif;
  font-size: 26rpx;
  font-weight: 500;
  color: #374151;
  line-height: 1.5;
  margin-bottom: 16rpx;
  padding-right: 30rpx;
}

.daily-actions {
  display: flex;
  gap: 16rpx;
}

.daily-tag {
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.daily-tag.do {
  background: rgba(167, 243, 208, 0.4);
  color: #059669;
}

.daily-tag.dont {
  background: rgba(254, 205, 211, 0.5);
  color: #E11D48;
}

.daily-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  font-size: 20rpx;
  color: #9CA3AF;
  padding: 10rpx;
}

/* ===== 首页姨妈日专属卡片内部排版 ===== */
.period-exclusive-status {
  display: flex;
  align-items: baseline;
  gap: 24rpx;
  margin-top: 10rpx;
  padding-top: 24rpx;
  border-top: 1rpx dashed rgba(216,183,200,0.6);
}

.period-exclusive-status .p-main {
  font-size: 46rpx;
  font-weight: 700;
  color: #986E81;
  letter-spacing: 2rpx;
}

.period-exclusive-status .p-sub {
  font-size: 26rpx;
  color: #986E81;
  opacity: 0.85;
  font-weight: 500;
}

/* ===== 首页姨妈日卡片红框区域填充样式 ===== */
.period-bottom-info {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.period-bottom-info .p-main {
  font-size: 34rpx;
  font-weight: 600;
  color: #986E81;
}

.period-bottom-info .p-sub {
  font-size: 24rpx;
  color: #986E81;
  opacity: 0.8;
  font-weight: 500;
}

.period-right-action {
  position: absolute;
  right: 36rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.p-action-btn {
  padding: 12rpx 26rpx;
  background: rgba(216,183,200,0.25);
  color: #986E81;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* ===== 每日黄历细条入口 ===== */
.huangli-strip {
  margin: 24rpx 36rpx 16rpx;
  min-height: 100rpx;
  padding: 20rpx 24rpx;
  border-radius: 30rpx;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.8), rgba(255,255,255,0.5)),
    radial-gradient(circle at 0% 0%, rgba(216,183,200,0.24), transparent 44%),
    radial-gradient(circle at 100% 10%, rgba(183,202,216,0.18), transparent 44%);
  border: 1rpx solid rgba(205,196,185,0.56);
  box-shadow: 0 16rpx 40rpx rgba(91,74,60,0.065);
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-sizing: border-box;
  backdrop-filter: blur(18px) saturate(132%);
  -webkit-backdrop-filter: blur(18px) saturate(132%);
}

.strip-date {
  min-width: 176rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding-right: 8rpx;
}

.strip-kicker {
  font-size: 18rpx;
  letter-spacing: 2.4rpx;
  color: #A87972;
  text-transform: uppercase;
}

.strip-day {
  font-size: 26rpx;
  font-weight: 700;
  color: #2F2A25;
  letter-spacing: 1rpx;
}

.strip-lunar {
  font-size: 19rpx;
  color: #7E766B;
  white-space: nowrap;
}

.strip-actions {
  flex: 1;
  min-width: 0;
  display: flex;
  gap: 12rpx;
  overflow: hidden;
}

.strip-pill {
  min-width: 0;
  flex: 1;
  padding: 12rpx 14rpx;
  border-radius: 20rpx;
  background:
    radial-gradient(circle at 30% 20%, rgba(255,255,255,0.4), transparent 48%),
    rgba(255,255,255,0.42);
  border: 1rpx solid rgba(205,196,185,0.44);
  color: #7E766B;
  font-size: 21rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.strip-pill-label {
  margin-right: 8rpx;
  font-weight: 700;
}

.strip-pill-label.good { color: #6F8773; }
.strip-pill-label.avoid { color: #A87972; }

.strip-pill-value {
  min-width: 0;
}

.strip-arrow {
  color: #AAA094;
  font-size: 40rpx;
  line-height: 1;
}
